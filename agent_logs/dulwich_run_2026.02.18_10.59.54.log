tion prefix\"\n        echo \"  --libdir         print the library installation directory\"\n        echo \"  --includedir     print the include directory\"\n        echo \"  --help           print this help message\"\n        ;;\n    *)\n        echo \"Usage: gpgme-config [OPTION]\" >&2\n        echo \"Try 'gpgme-config --help' for more information.\" >&2\n        exit 1\n        ;;\nesac\nEOF\n    chmod +x /usr/local/bin/gpgme-config\n\nCOPY *.sh $SRC/\nWORKDIR $SRC/dulwich\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/dulwich/build.sh\n---=== ORIGINAL ===---\n. \"$SRC/dulwich/fuzzing/oss-fuzz-scripts/build.sh\"\n---=== REPLACEMENT ===---\n# Modified to skip pgp extra if gpg package fails\ncd \"$SRC/dulwich\"\n# Try installing with pgp extra first, fall back to without pgp if it fails\nif python3 -m pip install -v \".[fastimport,paramiko,https,pgp]\"; then\n    echo \"Successfully installed dulwich with pgp extra\"\nelse\n    echo \"Failed to install with pgp extra, trying without pgp...\"\n    python3 -m pip install -v \".[fastimport,paramiko,https]\"\nfi\n# Continue with the rest of the build script\nfind \"$SRC\" -maxdepth 1 \\\n  \\( -name '*_seed_corpus.zip' -o -name '*.options' -o -name '*.dict' \\) \\\n  -exec printf '[%s] Copying: %s\\n' \"$(date '+%Y-%m-%d %H:%M:%S')\" {} \\; \\\n  -exec chmod a-x {} \\; \\\n  -exec cp {} \"$OUT\" \\;\n\n# Build fuzzers in $OUT.\nfind \"$SRC/dulwich/fuzzing\" -name 'fuzz_*.py' -print0 | while IFS= read -r -d '' fuzz_harness; do\n  compile_python_fuzzer \"$fuzz_harness\"\ndone"})
