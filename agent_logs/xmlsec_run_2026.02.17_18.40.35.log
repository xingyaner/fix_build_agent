ec source directory or configure.ac not found\"\n    echo \"Current directory: $(pwd)\"\n    echo \"Contents:\"\n    ls -la\n    exit 1\nfi\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/xmlsec/build.sh\n---=== ORIGINAL ===---\nfor file in $SRC/xmlsec/tests/oss-fuzz/*_target.c; do\n    b=$(basename $file _target.c)\n    echo -e \"#include <stdint.h>\\n$(cat $file)\" > $file\n    $CC $CFLAGS -c $file -I${XMLSEC_DEPS_PATH=}/include/libxml2 -I${XMLSEC_DEPS_PATH=}/include/ -I ./include/ \\\n    -o $OUT/${b}_target.o\n    $CXX $CXXFLAGS $OUT/${b}_target.o ./src/.libs/libxmlsec1.a \\\n    ./src/openssl/.libs/libxmlsec1-openssl.a $LIB_FUZZING_ENGINE \\\n    \"$XMLSEC_DEPS_PATH\"/lib/libxslt.a \"$XMLSEC_DEPS_PATH\"/lib/libxml2.a \\\n    -lz -llzma -o $OUT/${b}_fuzzer\ndone\n---=== REPLACEMENT ===---\n# Find xmlsec source directory - it might be in /src/xmlsec or /src/xmlsec_fixed\nXMLSEC_SRC_DIR=\"$SRC/xmlsec\"\nif [ ! -f \"$XMLSEC_SRC_DIR/configure.ac\" ] || ! grep -q \"xmlsec\" \"$XMLSEC_SRC_DIR/configure.ac\"; then\n    # Try alternative location\n    if [ -d \"/src/xmlsec_fixed\" ] && [ -f \"/src/xmlsec_fixed/configure.ac\" ] && grep -q \"xmlsec\" \"/src/xmlsec_fixed/configure.ac\"; then\n        XMLSEC_SRC_DIR=\"/src/xmlsec_fixed\"\n        echo \"Using xmlsec source from $XMLSEC_SRC_DIR\"\n    else\n        echo \"Error: Cannot find xmlsec source directory\"\n        echo \"Checked: $SRC/xmlsec and /src/xmlsec_fixed\"\n        exit 1\n    fi\nfi\n\n# Check if xmlsec tests directory exists\nif [ -d \"$XMLSEC_SRC_DIR/tests/oss-fuzz\" ]; then\n    for file in $XMLSEC_SRC_DIR/tests/oss-fuzz/*_target.c; do\n        b=$(basename $file _target.c)\n        echo -e \"#include <stdint.h>\\n$(cat $file)\" > $file\n        $CC $CFLAGS -c $file -I${XMLSEC_DEPS_PATH}/include/libxml2 -I${XMLSEC_DEPS_PATH}/include/ -I ./include/ \\\n        -o $OUT/${b}_target.o\n        $CXX $CXXFLAGS $OUT/${b}_target.o ./src/.libs/libxmlsec1.a \\\n        ./src/openssl/.libs/libxmlsec