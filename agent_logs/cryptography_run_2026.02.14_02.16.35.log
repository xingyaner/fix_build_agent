l/lib\"\nENV PKG_CONFIG_PATH=\"/usr/local/ssl/lib/pkgconfig:${PKG_CONFIG_PATH}\"\n\nCOPY build.sh fuzz_*.py $SRC/\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/cryptography/build.sh\n---=== ORIGINAL ===---\npython3 -m pip cache purge\n# Compiling with sancov is causing some issues at the moment. This is likely\n# due to some missing flags propagated throughout.\nunset RUSTFLAGS\nunset CXXFLAGS\nunset CFLAGS\npython3 -m pip install .\n\ncd $SRC\nfor fuzzer in $(find $SRC -name 'fuzz_*.py'); do\n   compile_python_fuzzer $fuzzer \ndone\n---=== REPLACEMENT ===---\npython3 -m pip cache purge\n# Compiling with sancov is causing some issues at the moment. This is likely\n# due to some missing flags propagated throughout.\nunset RUSTFLAGS\nunset CXXFLAGS\nunset CFLAGS\n\n# Set OpenSSL environment variables for build\nexport OPENSSL_DIR=\"/usr/local/ssl\"\nexport OPENSSL_INCLUDE_DIR=\"/usr/local/ssl/include\"\nexport OPENSSL_LIB_DIR=\"/usr/local/ssl/lib\"\nexport PKG_CONFIG_PATH=\"/usr/local/ssl/lib/pkgconfig:${PKG_CONFIG_PATH}\"\nexport LDFLAGS=\"-L/usr/local/ssl/lib ${LDFLAGS}\"\nexport CFLAGS=\"-I/usr/local/ssl/include ${CFLAGS}\"\n\npython3 -m pip install .\n\ncd $SRC\nfor fuzzer in $(find $SRC -name 'fuzz_*.py'); do\n   compile_python_fuzzer $fuzzer \ndone"})
