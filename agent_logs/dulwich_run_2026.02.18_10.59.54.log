   if pkg-config --exists gpgme; then\n        echo \"pkg-config found gpgme: $(pkg-config --modversion gpgme)\"\n    else\n        echo \"Warning: pkg-config cannot find gpgme\"\n    fi\nfi\n\n. \"$SRC/dulwich/fuzzing/oss-fuzz-scripts/build.sh\""})
