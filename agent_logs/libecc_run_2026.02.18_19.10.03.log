UNUSED(...)=(void)(__VA_ARGS__)/}\"\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/libecc/build.sh\n---=== ORIGINAL ===---\nexport CXXFLAGS=\"$CXXFLAGS -DCRYPTOFUZZ_BOTAN -DCRYPTOFUZZ_BOTAN_IS_ORACLE\"\nexport LIBBOTAN_A_PATH=\"$SRC/botan/libbotan-3.a\"\nexport BOTAN_INCLUDE_PATH=\"$SRC/botan/build/include\"\n---=== REPLACEMENT ===---\nexport CXXFLAGS=\"$CXXFLAGS -DCRYPTOFUZZ_BOTAN -DCRYPTOFUZZ_BOTAN_IS_ORACLE\"\nexport LIBBOTAN_A_PATH=\"$SRC/botan/libbotan-3.a\"\nexport BOTAN_INCLUDE_PATH=\"$SRC/botan/build/include\"\n# Also add BOTAN_UNUSED definition for cryptofuzz module compilation\nexport CXXFLAGS=\"$CXXFLAGS -DBOTAN_UNUSED(...)=(void)(__VA_ARGS__)\""})
