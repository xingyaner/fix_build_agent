\n\necho "XXXXXXXX" > $WORK/testinput\n\nfuzzers=$(find $BUILD/fuzz/ -executable -type f)\nfor f in $fuzzers; do\n\tfuzzer=$(basename $f)\n\tcp $f $OUT/\n\t# Check if it runs at least in build image\n\t$OUT/$fuzzer $WORK/testinput\n\t#zip -j $OUT/${fuzzer}_seed_corpus.zip fuzz/corpora/${fuzzer}/*\ndone\n\nrm $WORK/testinput\n\n### Content from: project.yaml ###\nhomepage: "https://gitlab.freedesktop.org/spice/libcacard"\nlanguage: c\nprimary_contact: "jjelen@redhat.com"\nauto_ccs:\n - "jakuje@gmail.com"\nsanitizers:\n - address\n - undefined\nmain_repo: \'https://gitlab.freedesktop.org/spice/libcacard.git\'\n\nfuzzing_engines:\n  - afl\n  - honggfuzz\n  - libfuzzer\n\n\n\n--- Project File Tree (Shallow View) ---\n📁 libcacard\n├── 📄 COPYING\n├── 📄 Makefile\n├── 📁 automation\n├── 📄 build.sh\n├── 📁 cmd\n├── 📁 coreconf\n├── 📁 cpputil\n├── 📁 doc\n├── 📄 exports.gyp\n├── 📁 fuzz\n├── 📁 gtests\n├── 📄 help.txt\n├── 📁 lib\n├── 📄 mach\n├── 📄 manifest.mn\n├── 📁 nss-tool\n├── 📄 nss.gyp\n├── 📁 pkg\n├── 📄 readme.md\n├── 📁 taskcluster\n├── 📁 tests\n└── 📄 trademarks.txt\n\n--- Recent Commit Changes ---\n--- Commit Context Information ---\nProject Name: libcacard\nError Report Time: 2025-11-22\nSelected Commit SHA: 55a385a19181c1d3622b3e4ce686ceee06202ddb\n------------------------------\n\ncommit 55a385a19181c1d3622b3e4ce686ceee06202ddb\nAuthor: John Schanck <jschanck@mozilla.com>\nDate:   Fri Nov 21 22:40:09 2025 +0000\n\n    Bug 2000737 - use hardware x64 GCM in static builds. r=nss-reviewers,nkulatova\n    \n    Differential Revision: https://phabricator.services.mozilla.com/D272965\n---\n lib/freebl/freebl.gyp  | 60 +++++++++++++++++++++++---------------------------\n lib/freebl/intel-gcm.s |  2 ++\n 2 files changed, 30 insertions(+), 32 deletions(-)\n\ndiff --git a/lib/freebl/freebl.gyp b/lib/freebl/freebl.gyp\nindex cd1dd710c..10a90d3f5 100644\n--- a/lib/freebl/freebl.gyp\n+++ b/lib/freebl/freebl.gyp\n@@ -24,14 +24,30 @@\n         \'intel-gcm-wrap.c\',\n       ],\n       \'dependencies\': [\n+        \'intel-gcm-s_lib\',\n         \'<(DEPTH)/exports.gyp:nss_exports\'\n       ],\n-      \'conditions\': [\n-        [ \'(OS=="linux" or OS=="android") and target_arch=="x64"\', {\n-          \'dependencies\': [\n-            \'intel-gcm-s_lib\',\n-          ],\n-        }],\n+      \'cflags\': [\n+        \'-mssse3\',\n+      ],\n+      \'cflags_mozilla\': [\n+        \'-mssse3\'\n+      ],\n+      # Remove FREEBL_NO_DEPEND so intel-gcm-wrap.c uses real NSS utility\n+      # functions instead of stubs. This is needed for static builds.\n+      \'defines!\': [\n+        \'FREEBL_NO_DEPEND\',\n+      ],\n+    },\n+    {\n+      \'target_name\': \'intel-gcm-wrap-nodepend_c_lib\',\n+      \'type\': \'static_library\',\n+      \'sources\': [\n+        \'intel-gcm-wrap.c\',\n+      ],\n+      \'dependencies\': [\n+        \'intel-gcm-s_lib\',\n+        \'<(DEPTH)/exports.gyp:nss_exports\'\n       ],\n       \'cflags\': [\n         \'-mssse3\',\n@@ -497,8 +513,10 @@\n         [ \'target_arch=="ia32" or target_arch=="x64"\', {\n           \'dependencies\': [\n             \'gcm-aes-x86_c_lib\',\n+            \'intel-gcm-wrap_c_lib\',\n           ],\n-        }, \'(disable_arm_hw_aes==0 or disable_arm_hw_sha1==0 or disable_arm_hw_sha2==0) and (target_arch=="arm" or target_arch=="arm64" or target_arch=="aarch64")\', {\n+        }],\n+        [ \'(disable_arm_hw_aes==0 or disable_arm_hw_sha1==0 or disable_arm_hw_sha2==0) and (target_arch=="arm" or target_arch=="arm64" or target_arch=="aarch64")\', {\n           \'dependencies\': [\n             \'armv8_c_lib\'\n           ],\n@@ -551,20 +569,6 @@\n           \'defines!\': [\n             \'FREEBL_NO_DEPEND\',\n             \'FREEBL_LOWHASH\',\n-            \'USE_HW_AES\',\n-            \'INTEL_GCM\',\n-            \'PPC_GCM\',\n-          ],\n-          \'conditions\': [\n-            [ \'target_arch=="x64"\', {\n-              # The AES assembler code doesn\'t work in static builds.\n-              # The