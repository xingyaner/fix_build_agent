Dockerfile ###\n# Copyright 2023 Google LLC\n#\n# Licensed under the Apache License, Version 2.0 (the "License");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\nFROM gcr.io/oss-fuzz-base/base-builder-rust@sha256:902cc445e3a2102a1e30b63000e855a3cf4064b763d0d5357433aba07ecdb887\nRUN git clone --depth 1 https://github.com/surrealdb/surrealdb surrealdb\nRUN git clone --depth 1 https://github.com/surrealdb/docs.surrealdb.com.git surrealdb_website\nWORKDIR surrealdb\n# Checkout the specific commit needed for fuzzing\nRUN git checkout 72c80c30a712ad0477a69f614308f556017c6b91\n# needed for MSAN and coverage build\nRUN rustup component add rust-src\n# Install lld linker for better compatibility\nRUN apt-get update && apt-get install -y lld\nCOPY build.sh $SRC/\n\n### Content from: build.sh ###\n#!/bin/bash -eu\n# Copyright 2023 Google LLC\n#\n# Licensed under the Apache License, Version 2.0 (the "License");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n# First check if we\'re in the right directory and if crates/ exists\nif [ -d "crates" ]; then\n    cd crates\nelif [ -d "surrealdb/crates" ]; then\n    cd surrealdb/crates\nelse\n    echo "ERROR: Could not find crates directory. Current directory: $(pwd)"\n    ls -la\n    exit 1\nfi\n\n# Copy dictionaries, but don\'t fail if there aren\'t any.\ncp fuzz/fuzz_targets/*.dict $OUT/ || true\n\n# Add additional compiler flags required for a successful build.\nexport RUSTFLAGS="$RUSTFLAGS --cfg surrealdb_unstable"\n\n# Disable the arbitrary feature to avoid compilation errors with missing trait implementations\n# Use cfg to conditionally compile out arbitrary derives\nexport RUSTFLAGS="$RUSTFLAGS --cfg arbitrary -C link-arg=-fuse-ld=lld"\ncargo fuzz build -O --debug-assertions --fuzz-dir fuzz --no-default-features\n\nFUZZ_TARGET_OUTPUT_DIR="fuzz/target/x86_64-unknown-linux-gnu/release"\nfor f in fuzz/fuzz_targets/*.rs\ndo\n    FUZZ_TARGET_NAME=$(basename ${f%.*})\n    cp $FUZZ_TARGET_OUTPUT_DIR/$FUZZ_TARGET_NAME $OUT/\n    # Create fuzz corpus, but don\'t fail if there aren\'t any.\n    zip $OUT/${FUZZ_TARGET_NAME}_seed_corpus.zip fuzz/fuzz_targets/${FUZZ_TARGET_NAME}_seed_corpus/* || true\ndone\n\nfind $SRC/surrealdb_website -name \'*.surql\' -exec zip -r $OUT/fuzz_executor_seed_corpus.zip {} \\;\n\n### Content from: project.yaml ###\nhomepage: "https://surrealdb.com/"\nlanguage: rust\nprimary_contact: "tobie@surrealdb.com"\nmain_repo: "https://github.com/surrealdb/surrealdb"\nauto_ccs:\n  - security@surrealdb.com\n  - mees.delzenne@surrealdb.com\n  - emmanuel.keller@surrealdb.com\n  - micha.de.vries@surrealdb.com\n  - rushmore@surrealdb.com\n  - rowan.baker@surrealdb.com\n\nsanitizers:\n  - address\nfuzzing_engines:\n  - libfuzzer\n\ncoverage_extra_args: >\n  -ignore-filename-regex=.*/rustc/.*\n\n--- Project File Tree (Shallow View) ---\n📁 surrealdb\n├── 📄 Makefile\n├── 📄 README.md\n├── 📄 astro.config.mjs\n├── 📁 aws\n├── 📄 biome.json\n├── 📄 bun.lockb\n├