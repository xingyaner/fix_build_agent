 libtiff if missing  \nif [ ! -d libtiff ]; then\n    echo \"Cloning libtiff repository...\"\n    git clone https://gitlab.com/libtiff/libtiff.git libtiff\nfi\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\nautoreconf -i\n\n# Check OpenSSL version and adjust configure flags if needed\n# curl may require OpenSSL 3.0.0+ but system has 1.1.1\n# Try with system OpenSSL first, fall back to without-ssl if needed\necho \"Configuring curl...\"\nif ./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install; then\n    echo \"Configured curl with OpenSSL support\"\nelse\n    echo \"OpenSSL 3.0.0+ not available, building curl without TLS support...\"\n    # Use --without-ssl (not --without-openssl) to disable all TLS/SSL\n    if ./configure --disable-shared --without-ssl --without-libpsl --prefix=$SRC/install; then\n        echo \"Configured curl without TLS support\"\n    else\n        echo \"ERROR: curl configure failed even without TLS\"\n        exit 1\n    fi\nfi\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n\n# build libtiff.a\ncd libtiff\n./autogen.sh\n\n# libtiff configure should work without special handling\n./configure --disable-shared --prefix=$SRC/install\n---=== REPLACEMENT ===---\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n\n# build libtiff.a\ncd libtiff\n./autogen.sh\n\n# libtiff configure should work without special handling\necho \"Configuring libtiff...\"\nif ./configure --disable-shared --prefix=$SRC/install; then\n    echo \"Configured libtiff successfully\"\nelse\n    echo \"ERROR: libtiff configure failed\"\n    exit 1\nfi\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\nmake -j$(nproc)\nmake install\ncd ..\n\nmkdir build\n---=== REPLACEMENT ===---\nmake -j$(nproc)\nmake install\ncd ..\n\nmkdir build\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/proj4/Dockerfile\n---=== ORIGINAL ===---\n# Clone dependencies to /src/ to avoid being overwritten by mount\nRUN git clone  https://github.com/curl/curl.git /src/curl\n\nRUN git clone  https://gitlab.com/libtiff/libtiff.git /src/libtiff\n---=== REPLACEMENT ===---\n# Clone dependencies to /src/ to avoid being overwritten by mount\n# These are available as backup if runtime cloning fails\nRUN git clone  https://github.com/curl/curl.git /src/curl\n\nRUN git clone  https://gitlab.com/libtiff/libtiff.git /src/libtiff\n"})
