2.69/g' configure.ac\n    echo \"Patched libtiff configure.ac to work with autoconf 2.69\"\nfi\n\n./fuzz/oss_fuzz_build.sh\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/libvips/Dockerfile\n---=== ORIGINAL ===---\nRUN apt-get update && apt-get install -y \\\n  autoconf \\\n  autoconf-archive \\\n  automake \\\n  autopoint \\\n  cmake \\\n  curl \\\n  gettext \\\n  glib2.0-dev \\\n  libbrotli-dev \\\n  libexpat1-dev \\\n  libffi-dev \\\n  libfftw3-dev \\\n  libselinux1-dev \\\n  libtool \\\n  nasm \\\n  python3-pip\nRUN pip3 install meson ninja\nRUN autoconf --version\n---=== REPLACEMENT ===---\nRUN apt-get update && apt-get install -y \\\n  autoconf \\\n  autoconf-archive \\\n  automake \\\n  autopoint \\\n  cmake \\\n  curl \\\n  gettext \\\n  glib2.0-dev \\\n  libbrotli-dev \\\n  libexpat1-dev \\\n  libffi-dev \\\n  libfftw3-dev \\\n  libselinux1-dev \\\n  libtool \\\n  nasm \\\n  python3-pip\nRUN pip3 install meson ninja\n# Install newer autoconf from source since Ubuntu repos only have 2.69\n# and libtiff requires 2.71+ (we'll patch it to work with 2.69, but also install newer)\nRUN cd /tmp && \\\n    curl -L -o autoconf-2.71.tar.gz https://ftp.gnu.org/gnu/autoconf/autoconf-2.71.tar.gz && \\\n    tar -xzf autoconf-2.71.tar.gz && \\\n    cd autoconf-2.71 && \\\n    ./configure --prefix=/usr/local && \\\n    make -j$(nproc) && \\\n    make install && \\\n    rm -rf /tmp/autoconf-2.71*\nRUN autoconf --version\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/libvips/build.sh\n---=== ORIGINAL ===---\n# Patch libtiff's configure.ac to work with autoconf 2.69\n# The error is: configure.ac:27: error: Autoconf version 2.71 or higher is required\n# We patch it to require 2.69 instead\ncd /src/libtiff\nif [ -f configure.ac ]; then\n    sed -i 's/AC_PREREQ(\\[2\\.71\\])/AC_PREREQ([2.69])/g' configure.ac\n    # Also check for other occurrences of 2.71\n    sed -i 's/2\\.71/2.69/g' configure.ac\n    echo \"Patched libtiff configure.ac to work with autoconf 2.69\"\nfi\n\n./fuzz/oss_fuzz_build.sh\n---=== REPLACEMENT ===---\n#!/bin/bash -eu\n# Copyright 2019 Google Inc.\n#\n# Licensed under the Apache License, Version 2.0 (the \"License\");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\n# Patch libtiff's configure.ac to work with autoconf 2.69\n# The error is: configure.ac:27: error: Autoconf version 2.71 or higher is required\n# We patch it to require 2.69 instead\ncd /src/libtiff\nif [ -f configure.ac ]; then\n    sed -i 's/AC_PREREQ(\\[2\\.71\\])/AC_PREREQ([2.69])/g' configure.ac\n    # Also check for other occurrences of 2.71\n    sed -i 's/2\\.71/2.69/g' configure.ac\n    echo \"Patched libtiff configure.ac to work with autoconf 2.69\"\nfi\n\n# Also check for highway library compilation issues\n# The original error was in /work/include/hwy/base.h with HWY_FLOAT16_BINARY_OP macros\n# This might be a C++ standard or compiler flag issue\n# Add -std=c++17 flag to ensure proper C++17 support\nexport CXXFLAGS=\"$CXXFLAGS -std=c++17\"\nexport CFLAGS=\"$CFLAGS -std=c99\"\n\n./fuzz/oss_fuzz_build.sh"})
