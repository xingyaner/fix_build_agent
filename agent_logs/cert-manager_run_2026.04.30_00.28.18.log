  - TOOL_CALL: create_or_update_file({"file_path": "/home/senchen/temp/fix_build_agent/oss-fuzz/projects/cert-manager/build.sh", "content": "cp $SRC/pki_fuzzer.go $SRC/cert-manager/pkg/util/pki/\n\n# Patch go-118-fuzz-build to handle Go 1.25+ toolchain under GOMODCACHE.\n# In Go 1.25+, GOROOT is under GOMODCACHE and overlay replacements beneath\n# GOMODCACHE are forbidden. We modify go-118-fuzz-build to:\n# 1. Skip overlay for stdlib files (testing/fuzz.go, testing/testing.go)\n# 2. Include the custom testing.F implementation directly in the generated main file\ncd /tmp/go-118-fuzz-build\n\n# Step 1: Comment out the overlay entries for stdlib files\nsed -i 's|walker\\.overlayMap\\.Replace\\[filepath\\.Join(walker\\.goRootDir, \"src/testing/fuzz\\.go\")\\] = fuzzGoFile\\.Name()|// Disabled for Go 1.25+ compatibility|' file_walker.go\nsed -i 's|walker\\.overlayMap\\.Replace\\[filepath\\.Join(walker\\.goRootDir, \"src/testing/testing\\.go\")\\] = testingGoFile\\.Name()|// Disabled for Go 1.25+ compatibility|' file_walker.go\n\n# Step 2: Modify the main template to replace testing.NewF with a local implementation\npython3 << 'PYEOF'\nwith open('main.go', 'r') as f:\n    content = f.read()\n\n# Find the main template boundaries\nstart_marker = 'var mainTmpl = template.Must(template.New(\"main\").Parse(`'\nend_marker = '`))\\n\\nvar coverageTmpl'\n\nstart_idx = content.find(start_marker)\nend_idx = content.find(end_marker)\n\nif start_idx == -1:\n    print(\"ERROR: Could not find start marker\")\n    exit(1)\nif end_idx == -1:\n    print(\"ERROR: Could not find end marker\")\n    exit(1)\n\n# Extract the template\ntemplate = content[start_idx:end_idx]\n\n# Modify the import section to add needed packages\nold_imports = '''import (\n\\t\"runtime\"\n\\t\"strings\"\n\\t\"unsafe\"\n\\ttarget {{printf \"%q\" .PkgPath}}\n\\t\"testing\"\n)'''\n\nnew_imports = '''import (\n\\t\"runtime\"\n\\t\"strings\"\n\\t\"unsafe\"\n\\ttarget {{printf \"%q\" .PkgPath}}\n\\t\"testing\"\n\\t\"reflect\"\n\\t\"encoding/binary\"\n\\t\"io\"\n\\t\"math\"\n\\t\"os\"\n\\t\"fmt\"\n)'''\n\nif old_imports not in template:\n    print(\"ERROR: Could not find old imports in template\")\n    print(\"Template snippet:\", template[:500])\n    exit(1)\n\ntemplate = template.replace(old_imports, new_imports)\n\n# Replace testing.NewF with localFNew\ntemplate = template.replace('fuzzer := testing.NewF(data)', 'fuzzer := localFNew(data)')\n\n# Add the local F implementation before the LLVMFuzzerTestOneInput function\ninsert_marker = '//export LLVMFuzzerTestOneInput'\nlocal_f_code = '''\ntype localF struct {\n\\ts *localSource\n\\tTempDirs []string\n}\n\nfunc localFNew(data []byte) *localF {\n\\treturn &localF{s: localNewSource(data), TempDirs: make([]string, 0)}\n}\n\nfunc (f *localF) CleanupTempDirs() {\n\\tfor _, tempDir := range f.TempDirs {\n\\t\\tos.RemoveAll(tempDir)\n\\t}\n}\n\nfunc (f *localF) Add(args ...any)                   {}\nfunc (f *localF) Cleanup(f func())                  {}\nfunc (f *localF) Error(args ...any)                 {}\nfunc (f *localF) Errorf(format string, args ...any) {}\nfunc (f *localF) Fail()                             {}\nfunc (f *localF) FailNow()                          {}\nfunc (f *localF) Failed() bool                      { return false }\nfunc (f *localF) Fatal(args ...any)                 {}\nfunc (f *localF) Fatalf(format string, args ...any) {}\nfunc (f *localF) Helper() {}\nfunc (f *localF) Log(args ...any) {\n\\tfmt.Print(args...)\n}\nfunc (f *localF) Logf(format string, args ...any) {\n\\tfmt.Println(fmt.Sprintf(format, args...))\n}\nfunc (f *localF) Name() string             { return \"libFuzzer\" }\nfunc (f *localF) Setenv(key, value string) {}\nfunc (f *localF) Skip(args ...any) {\n\\tpanic(\"GO-FUZZ-BUILD-PANIC\")\n}\nfunc (f *localF) SkipNow() {\n\\tpanic(\"GO-FUZZ-BUILD-PANIC\")\n}\nfunc (f *localF) Skipf(format string, args ...any) {\n\\tpanic(\"GO-FUZZ-BUILD-PANIC\")\n}\nfunc (f *localF) Skipped() bool { return false }\n\nfunc (f *localF) TempDir() string {\n\\tdir, err := os.MkdirTemp(\"\", \"fuzzdir-\")\n\\tif err != nil {\n\\t\\tpanic(err)\n\\t}\n\\tf.TempDirs = append(f.TempDirs, dir)\n\\treturn dir\n}\n\ntype localSource struct {\n\\ts         []byte\n\\ti         int64\n\\texhausted bool\n}\n\nfunc localNewSource(data []byte) *localSource {\n\\treturn &localSource{data, 0, false}\n}\n\nfunc (s *localSource) IsExhausted() bool {\n\\treturn s.exhausted\n}\n\nfunc (s *localSource) Len() int {\n\\tif s.i >= int64(len(s.s)) {\n\\t\\treturn 0\n\\t}\n\\treturn int(int64(len(s.s)) - s.i)\n}\n\nfunc (s *localSource) Used() int {\n\\treturn int(s.i)\n}\n\nfunc (s *localSource) Read(b []byte) (n int, err error) {\n\\tif s.i >= int64(len(s.s)) {\n\\t\\tn, err = 0, io.EOF\n\\t} else {\n\\t\\tn = copy(b, s.s[s.i:])\n\\t\\ts.i += int64(n)\n\\t}\n\\tif n < len(b) {\n\\t\\ts.exhausted = true\n\\t}\n\\treturn n, err\n}\n\nfunc (s *localSource) getBytes(size int) []byte {\n\\tif end := int(s.i) + size; end < len(s.s) {\n\\t\\tpos := s.i\n\\t\\ts.i += int64(size)\n\\t\\treturn s.s[pos:end]\n\\t}\n\\tbuf := make([]byte, size)\n\\ts.Read(buf)\n\\treturn buf\n}\n\nfunc (s *localSource) readInt(num reflect.Kind) int64 {\n\\tswitch num {\n\\tcase reflect.Int8:\n\\t\\treturn int64(int8(s.getBytes(1)[0]))\n\\tcase reflect.Int16:\n\\t\\treturn int64(int16(binary.BigEndian.Uint16(s.getBytes(2))))\n\\tcase reflect.Int32:\n\\t\\treturn int64(int32(binary.BigEndian.Uint32(s.getBytes(4))))\n\\tcase reflect.Int64, reflect.Int:\n\\t\\treturn int64(binary.BigEndian.Uint64(s.getBytes(8)))\n\\t}\n\\tpanic(fmt.Sprintf(\"unsupported type: %v\", num))\n}\n\nfunc (s *localSource) readUint(num reflect.Kind) uint64 {\n\\tswitch num {\n\\tcase reflect.Uint8:\n\\t\\treturn uint64(uint8(s.getBytes(1)[0]))\n\\tcase reflect.Uint16:\n\\t\\treturn uint64(binary.BigEndian.Uint16(s.getBytes(2)))\n\\tcase reflect.Uint32:\n\\t\\treturn uint64(binary.BigEndian.Uint32(s.getBytes(4)))\n\\tcase reflect.Uint, reflect.Uint64:\n\\t\\treturn binary.BigEndian.Uint64(s.getBytes(8))\n\\t}\n\\tpanic(fmt.Sprintf(\"unsupported type: %v\", num))\n}\n\nfunc (s *localSource) fillArg(v reflect.Type, max int) reflect.Value {\n\\tnewElem := reflect.New(v).Elem()\n\\tswitch k := v.Kind(); k {\n\\tcase reflect.Int, reflect.Int8, reflect.Int16, reflect.Int32, reflect.Int64:\n\\t\\tnewElem.SetInt(s.readInt(k))\n\\tcase reflect.Uint, reflect.Uint8, reflect.Uint16, reflect.Uint32, reflect.Uint64:\n\\t\\tnewElem.SetUint(s.readUint(k))\n\\tcase reflect.Float32:\n\\t\\tnewElem.Set(reflect.ValueOf(math.Float32frombits(uint32(s.readUint(reflect.Uint32)))))\n\\tcase reflect.Float64:\n\\t\\tnewElem.Set(reflect.ValueOf(math.Float64frombits(s.readUint(reflect.Uint64))))\n\\tcase reflect.Bool:\n\\t\\tnewElem.Set(reflect.ValueOf(s.readUint(reflect.Uint8)&0x1 != 0))\n\\tcase reflect.String:\n\\t\\tnewElem.SetString(string(s.getBytes(max)))\n\\tcase reflect.Slice:\n\\t\\tif v.Elem().Kind() == reflect.Uint8 {\n\\t\\t\\tnewElem.SetBytes(s.getBytes(max))\n\\t\\t} else {\n\\t\\t\\tpanic(fmt.Sprintf(\"unsupported type: %T\", newElem.Kind))\n\\t\\t}\n\\tdefault:\n\\t\\tpanic(fmt.Sprintf(\"unsupported type: %T\", newElem.Kind))\n\\t}\n\\treturn newElem\n}\n\nfunc (s *localSource) FillAndCall(ff any, arg0 reflect.Value) (ok bool) {\n\\tfn := reflect.ValueOf(ff)\n\\tmethod := fn.Type()\n\\tif method.Kind() != reflect.Func {\n\\t\\tpanic(fmt.Sprintf(\"wrong type: %T\", ff))\n\\t}\n\\targs := make([]reflect.Value, method.NumIn())\n\\targs[0] = arg0\n\\tvar dynamic []int\n\\tfor i := 1; i < method.NumIn(); i++ {\n\\t\\tv := method.In(i)\n\\t\\tif v.Kind() <= reflect.Float64 {\n\\t\\t\\targs[i] = s.fillArg(v, 0)\n\\t\\t} else {\n\\t\\t\\tdynamic = append(dynamic, i)\n\\t\\t}\n\\t}\n\\tweights := s.getBytes(len(dynamic))\n\\tsum := 0\n\\tfor _, v := range weights {\n\\t\\tsum += int(v)\n\\t}\n\\tbytesLeft := s.Len()\n\\tfor i, argNum := range dynamic {\n\\t\\tif i == len(dynamic)-1 {\n\\t\\t\\targs[argNum] = s.fillArg(method.In(argNum), s.Len())\n\\t\\t\\tbreak\n\\t\\t}\n\\t\\tvar argSize = bytesLeft / len(dynamic)\n\\t\\tif sum > 0 {\n\\t\\t\\targSize = (bytesLeft * int(weights[i])) / sum\n\\t\\t}\n\\t\\targs[argNum] = s.fillArg(method.In(argNum), argSize)\n\\t}\n\\tfn.Call(args)\n\\treturn true\n}\n\n'''\n\nif insert_marker not in template:\n    print(\"ERROR: Could not find insert marker in template\")\n    print(\"Looking for:\", repr(insert_marker))\n    print(\"Template contains 'LLVMFuzzerTestOneInput':\", 'LLVMFuzzerTestOneInput' in template)\n    exit(1)\n\ntemplate = template.replace(insert_marker, local_f_code + insert_marker)\n\n# Reconstruct the file\nnew_content = content[:start_idx] + template + content[end_idx:]\n\nwith open('main.go', 'w') as f:\n    f.write(new_content)\n\nprint(\"Main template patched successfully\")\nPYEOF\n\ngo build -o /root/go/bin/go-118-fuzz-build_v2 .\n\ncd $SRC/cert-manager\ngo mod tidy\ncompile_native_go_fuzzer_v2 github.com/cert-manager/cert-manager/internal/webhook/admission/certificaterequest/approval FuzzValidate FuzzValidate_approval\ncompile_native_go_fuzzer_v2 github.com/cert-manager/cert-manager/pkg/controller/certificates/trigger FuzzProcessItem FuzzProcessItem_trigger\ncompile_native_go_fuzzer_v2 github.com/cert-manager/cert-manager/pkg/controller/certificates/revisionmanager FuzzProcessItem FuzzProcessItem_revisionmanager\ncompile_native_go_fuzzer_v2 github.com/cert-manager/cert-manager/pkg/controller/certificates/issuing FuzzProcessItem FuzzProcessItem_issuing\ncompile_native_go_fuzzer_v2 github.com/cert-manager/cert-manager/pkg/controller/certificates/readiness FuzzProcessItem FuzzProcessItem_readiness\ncompile_native_go_fuzzer_v2 github.com/cert-manager/cert-manager/pkg/controller/certificates/keymanager FuzzProcessItem FuzzProcessItem_keymanager\ncompile_native_go_fuzzer_v2 github.com/cert-manager/cert-manager/pkg/controller/certificates/requestmanager FuzzProcessItem FuzzProcessItem_requestmanager\ncompile_native_go_fuzzer_v2 github.com/cert