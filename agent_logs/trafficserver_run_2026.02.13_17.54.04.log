XXFLAGS=\"${CXXFLAGS} -I${BORINGSSL_PATH}/include -std=gnu++17\" \\\n  LDFLAGS=\"${LDFLAGS}\" \\\n  OPENSSL_LIBS=\"-lcrypto -lssl -L${BORINGSSL_LIB_PATH}\" \\\n  --enable-http3 \\\n  --disable-examples \\\n  ${ENABLE_APP}\n${MAKE} -j ${num_threads}\nsudo ${MAKE} install\nsudo chmod -R a+rX ${BASE}\ncd ..\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/trafficserver/Dockerfile\n---=== ORIGINAL ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:c099d3d710d12d5d9a39498463ff10973977d1c7a85e9a0fbe00c7f0a0fa9fb8\nRUN apt-get update && apt-get install -y libpcre3-dev zlib1g-dev cmake libssl-dev libpcre2-dev pkg-config libc-ares-dev\nRUN git clone  https://github.com/apache/trafficserver.git\nRUN cp $SRC/trafficserver/tests/fuzzing/oss-fuzz.sh $SRC/build.sh\nWORKDIR $SRC/trafficserver/\n---=== REPLACEMENT ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:c099d3d710d12d5d9a39498463ff10973977d1c7a85e9a0fbe00c7f0a0fa9fb8\nRUN apt-get update && apt-get install -y libpcre3-dev zlib1g-dev cmake libssl-dev libpcre2-dev pkg-config libc-ares-dev libc++-dev libc++abi-dev\nRUN git clone  https://github.com/apache/trafficserver.git\nRUN cp $SRC/trafficserver/tests/fuzzing/oss-fuzz.sh $SRC/build.sh\nWORKDIR $SRC/trafficserver/\n---=== FILE ===---\n/root/fix_build_agent/process/project/trafficserver/tools/build_boringssl_h3_tools.sh\n---=== ORIGINAL ===---\n# Now ngtcp2\necho \"Building ngtcp2...\"\n[ ! -d ngtcp2 ] && git clone --depth 1 -b v1.11.0 https://github.com/ngtcp2/ngtcp2.git\ncd ngtcp2\nautoreconf -if\n./configure \\\n  --prefix=${BASE} \\\n  --with-boringssl \\\n  BORINGSSL_CFLAGS=\"-I${BORINGSSL_PATH}/include\" \\\n  BORINGSSL_LIBS=\"-L${BORINGSSL_LIB_PATH} -lssl -lcrypto\" \\\n  PKG_CONFIG_PATH=${BASE}/lib/pkgconfig \\\n  CFLAGS=\"${CFLAGS} -fPIC\" \\\n  CXXFLAGS=\"${CXXFLAGS} -fPIC\" \\\n  LDFLAGS=\"${LDFLAGS}\" \\\n  --enable-lib-only\n${MAKE} -j ${num_threads}\nsudo ${MAKE} install\nsudo chmod -R a+rX ${BASE}\ncd ..\n---=== REPLACEMENT ===---\n# Now ng