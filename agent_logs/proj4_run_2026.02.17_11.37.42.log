  - TOOL_CALL: create_or_update_file({"file_path": "solution.txt", "content": "---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/proj4/Dockerfile\n---=== ORIGINAL ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:cede7bc2cc2ece182ffb31a0d118e0e3ade537b2ea40803829f19373815bb8f8\nRUN apt-get update && \\\n    apt-get install -y make autoconf automake libtool g++ sqlite3 pkg-config wget perl libtext-template-perl\n\nRUN git clone  https://github.com/OSGeo/PROJ PROJ\n\nRUN git clone  https://github.com/curl/curl.git PROJ/curl\n\nRUN git clone  https://gitlab.com/libtiff/libtiff.git PROJ/libtiff\n\nWORKDIR PROJ\n\n# Create a wrapper script that ensures we're in the right directory\nRUN echo '#!/bin/bash' > /src/build.sh && \\\n    echo 'cd /src/PROJ' >> /src/build.sh && \\\n    echo 'exec /src/PROJ/test/fuzzers/build.sh \"$@\"' >> /src/build.sh && \\\n    chmod +x /src/build.sh\n\n# Also copy the original for reference\nRUN cp test/fuzzers/build.sh $SRC/build.sh.orig\n---=== REPLACEMENT ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:cede7bc2cc2ece182ffb31a0d118e0e3ade537b2ea40803829f19373815bb8f8\n# Install build dependencies WITHOUT libssl-dev (we'll build OpenSSL 3.x ourselves)\nRUN apt-get update && \\\n    apt-get install -y make autoconf automake libtool g++ sqlite3 pkg-config wget perl libtext-template-perl\n\n# Build OpenSSL 3.x from source with custom prefix\nRUN wget https://www.openssl.org/source/openssl-3.0.13.tar.gz && \\\n    tar -xzf openssl-3.0.13.tar.gz && \\\n    cd openssl-3.0.13 && \\\n    ./config --prefix=/opt/openssl3 --openssldir=/opt/openssl3 no-shared && \\\n    make -j$(nproc) && \\\n    make install && \\\n    cd .. && \\\n    rm -rf openssl-3.0.13 openssl-3.0.13.tar.gz\n\n# Set up environment to use our custom OpenSSL 3.x\nENV OPENSSL_ROOT_DIR=/opt/openssl3\nENV PKG_CONFIG_PATH=/opt/openssl3/lib/pkgconfig:$PKG_CONFIG_PATH\nENV LD_LIBRARY_PATH=/opt/openssl3/lib:$LD_LIBRARY_PATH\nENV PATH=/opt/openssl3/bin:$PATH\n\nRUN git clone  https://github.com/OSGeo/PROJ PROJ\n\nRUN git clone  https://github.com/curl/curl.git PROJ/curl\n\nRUN git clone  https://gitlab.com/libtiff/libtiff.git PROJ/libtiff\n\nWORKDIR PROJ\n\n# Create a wrapper script that ensures we're in the right directory\nRUN echo '#!/bin/bash' > /src/build.sh && \\\n    echo 'cd /src/PROJ' >> /src/build.sh && \\\n    echo 'exec /src/PROJ/test/fuzzers/build.sh \"$@\"' >> /src/build.sh && \\\n    chmod +x /src/build.sh\n\n# Also copy the original for reference\nRUN cp test/fuzzers/build.sh $SRC/build.sh.orig\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\nI386_PACKAGES=\"zlib1g-dev:i386 libssl-dev:i386 libsqlite3-dev:i386\"\nX64_PACKAGES=\"zlib1g-dev libssl-dev libsqlite3-dev\"\n\nif [ \"$ARCHITECTURE\" = \"i386\" ]; then\n    apt-get install -y $I386_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\" -DSQLite3_LIBRARY=/lib/i386-linux-gnu/libsqlite3.a\"\nelse\n    apt-get install -y $X64_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\"\"\nfi\n\n# Set environment variables to use our custom OpenSSL 3.x build\nexport PKG_CONFIG_PATH=/usr/local/ssl3/lib/pkgconfig:$PKG_CONFIG_PATH\nexport LD_LIBRARY_PATH=/usr/local/ssl3/lib:$LD_LIBRARY_PATH\nexport CFLAGS=\"-I/usr/local/ssl3/include $CFLAGS\"\nexport LDFLAGS=\"-L/usr/local/ssl3/lib $LDFLAGS\"\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\nautoreconf -i\n./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install --with-ssl=/usr/local/ssl3\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== REPLACEMENT ===---\nI386_PACKAGES=\"zlib1g-dev:i386 libsqlite3-dev:i386\"\nX64_PACKAGES=\"zlib1g-dev libsqlite3-dev\"\n\nif [ \"$ARCHITECTURE\" = \"i386\" ]; then\n    apt-get install -y $I386_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\" -DSQLite3_LIBRARY=/lib/i386-linux-gnu/libsqlite3.a\"\nelse\n    apt-get install -y $X64_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\"\"\nfi\n\n# Verify OpenSSL 3.x is available (should be set up in Dockerfile)\nif [ ! -d \"/opt/openssl3\" ]; then\n    echo \"ERROR: OpenSSL 3.x not found at /opt/openssl3\"\n    echo \"Please ensure the Dockerfile builds OpenSSL 3.x to /opt/openssl3\"\n    exit 1\nfi\n\necho \"Using OpenSSL from: /opt/openssl3\"\necho \"OpenSSL version: $(/opt/openssl3/bin/openssl version)\"\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\nautoreconf -i\n# Use the OpenSSL from our custom installation\n./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install --with-ssl=/opt/openssl3\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\nEXTRA_LIBS=\"-lpthread -Wl,-Bstatic -lsqlite3 -L$SRC/install/lib -ltiff -lcurl -L/usr/local/ssl3/lib -lssl -lcrypto -lz -Wl,-Bdynamic\"\n---=== REPLACEMENT ===---\nEXTRA_LIBS=\"-lpthread -Wl,-Bstatic -lsqlite3 -L$SRC/install/lib -ltiff -lcurl -L/opt/openssl3/lib -lssl -lcrypto -lz -Wl,-Bdynamic\""})
