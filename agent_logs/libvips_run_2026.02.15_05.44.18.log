ips.git\nRUN git clone  https://github.com/madler/zlib.git\nRUN git clone  https://github.com/libexif/libexif.git\nRUN git clone  https://github.com/mm2/Little-CMS.git lcms\nRUN git clone  https://github.com/libjpeg-turbo/libjpeg-turbo.git\nRUN git clone  https://github.com/pnggroup/libpng.git\nRUN git clone  https://chromium.googlesource.com/webm/libwebp\nRUN git clone  https://gitlab.com/libtiff/libtiff.git\nRUN git clone  https://aomedia.googlesource.com/aom\nRUN git clone  https://github.com/strukturag/libheif.git\nRUN git clone  https://github.com/libjxl/libjxl.git\nRUN git clone  https://github.com/lovell/libimagequant.git\nRUN git clone  https://github.com/dloebl/cgif.git\nRUN git clone  https://github.com/google/highway.git\nRUN git clone  https://github.com/google/libultrahdr.git\n\nWORKDIR libultrahdr\nCOPY build.sh $SRC/\n\n### Content from: build.sh ###\n#!/bin/bash -eu\n# Copyright 2019 Google Inc.\n#\n# Licensed under the Apache License, Version 2.0 (the "License");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\n#!/bin/bash -eu\n# Copyright 2019 Google Inc.\n#\n# Licensed under the Apache License, Version 2.0 (the "License");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\n# Build libultrahdr\nmkdir -p build\ncd build\ncmake .. -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX \\\n  -DCMAKE_C_FLAGS="$CFLAGS" -DCMAKE_CXX_FLAGS="$CXXFLAGS" \\\n  -DBUILD_SHARED_LIBS=OFF -DUHDR_BUILD_TESTS=OFF -DUHDR_BUILD_DEPS=1\nmake -j$(nproc)\n\n# Build fuzzers\nfor fuzzer in $(find ../fuzzer -name \'*_fuzzer.cpp\'); do\n  fuzzer_basename=$(basename $fuzzer .cpp)\n  $CXX $CXXFLAGS -std=c++17 -I../lib -I../inc \\\n    $fuzzer ../lib/*.cc -o $OUT/$fuzzer_basename \\\n    $LIB_FUZZING_ENGINE ./libultrahdr.a\ndone\n\n### Content from: project.yaml ###\nhomepage: "https://github.com/libvips/libvips"\nlanguage: c++\nprimary_contact: "jcupitt@gmail.com"\nauto_ccs:\n  - "kleisauke@gmail.com"\n  - "lovell.fuller@gmail.com"\nmain_repo: \'https://github.com/libvips/libvips\'\nfuzzing_engines:\n  - afl\n  - honggfuzz\n  - libfuzzer\ncoverage_extra_args: -sources src/libvips\n\n\n--- Project File Tree (Shallow View) ---\n📁 libvips\n├── 📄 Android.bp\n├── 📄 CMakeLists.txt\n├── 📄 DESCRIPTION\n├── 📄 LICENSE\n├── 📄 README.md\n├── 📁 adobe-hdr-gain-map-license\n├── 📁 benchmark\n├── 📁 cmake\n├── 📁 docs\n├── 📁 examples\n├── 📁 fuzzer\n├── 📁 java\n├── 📁 lib\n├── 📁 tests\n├── 📁 third_party\n└── 📄 ultrahdr_api.h\n\n--- Recent Commit Changes ---\nNo relevant commit found.\n\n--- Fuzz Build Log (Last 500 lines) ---\n#6 20.82 Setting up cmake-data (3.16.3-1ubuntu1.20.04.1) ...\n#6 20.83 Setting up libmpdec2:amd64 (2.4.2-3) ...\n#6 20.83 Setting up libpython3.8-stdlib:amd64 (3.8.10-0ubuntu1~20.04.18) ...\n#6 20.84 Setting up python3.8 (3.8.10-0ubuntu1~20.04.18) ...\n#6 21.34 Setting up libelf1:amd64 (0.176-1.1ubuntu0.1) ...\n#6 21.34 Setting up libxml2:amd64 (2.9.10+dfsg-5ubuntu0.20.04.10) ...\n#6 21.35 Setting up libbrot