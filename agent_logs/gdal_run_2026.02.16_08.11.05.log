  - TOOL_CALL: create_or_update_file({"file_path": "solution.txt", "content": "---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/gdal/Dockerfile\n---=== ORIGINAL ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:da1935bce8ffd5308f198945e0902752866aeb835b461aa0e64367b144af0327\nRUN apt-get update && \\\n    apt-get install -y make autoconf automake libtool g++ curl cmake sqlite3 pkg-config\n\nRUN git clone  https://github.com/OSGeo/gdal gdal\n\nRUN cp gdal/fuzzers/build.sh $SRC/\n\nWORKDIR gdal\n---=== REPLACEMENT ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:da1935bce8ffd5308f198945e0902752866aeb835b461aa0e64367b144af0327\nRUN apt-get update && \\\n    apt-get install -y make autoconf automake libtool g++ curl cmake sqlite3 pkg-config \\\n    libbrotli-dev libbz2-dev\n\nRUN git clone  https://github.com/OSGeo/gdal gdal\n\nRUN cp gdal/fuzzers/build.sh $SRC/\n\nWORKDIR gdal\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\n          libwebp-dev${ARCH_SUFFIX} \\\n          libzstd-dev${ARCH_SUFFIX} \\\n          libssl-dev${ARCH_SUFFIX} \\\n          libfreetype6-dev${ARCH_SUFFIX} libfontconfig1-dev${ARCH_SUFFIX} libtiff5-dev${ARCH_SUFFIX} libboost-dev${ARCH_SUFFIX}\"\n---=== REPLACEMENT ===---\n          libzstd-dev${ARCH_SUFFIX} \\\n          libssl-dev${ARCH_SUFFIX} \\\n          libfreetype6-dev${ARCH_SUFFIX} libfontconfig1-dev${ARCH_SUFFIX} libtiff5-dev${ARCH_SUFFIX} libboost-dev${ARCH_SUFFIX}\"\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\nrm -rf freetype-2.13.2\ncurl -L https://download.savannah.gnu.org/releases/freetype/freetype-2.13.2.tar.xz > freetype-2.13.2.tar.xz && \\\n    tar xJf freetype-2.13.2.tar.xz && \\\n    rm freetype-2.13.2.tar.xz\n---=== REPLACEMENT ===---\n# Build libwebp from source to get sharpyuv support\nrm -rf libwebp\ngit clone --depth 1 https://chromium.googlesource.com/webm/libwebp libwebp\n\nrm -rf freetype-2.13.2\ncurl -L https://download.savannah.gnu.org/releases/freetype/freetype-2.13.2.tar.xz > freetype-2.13.2.tar.xz && \\\n    tar xJf freetype-2.13.2.tar.xz && \\\n    rm freetype-2.13.2.tar.xz\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\n# build freetype\ncd freetype-2.13.2\nCFLAGS=\"$NON_FUZZING_CFLAGS\" ./configure --prefix=$SRC/install\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== REPLACEMENT ===---\n# build libwebp\ncd libwebp\n./autogen.sh\nCFLAGS=\"$NON_FUZZING_CFLAGS\" ./configure --prefix=$SRC/install --disable-shared --enable-static --enable-libwebpdecoder --enable-libwebpdemux --enable-libwebpmux\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n\n# build freetype\ncd freetype-2.13.2\nCFLAGS=\"$NON_FUZZING_CFLAGS\" ./configure --prefix=$SRC/install\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\nexport EXTRA_LIBS=\"$EXTRA_LIBS -ljbig -lzstd -lwebp -llzma -lexpat -L$SRC/install/lib -lsqlite3 -lgif -ljpeg -lpng -lz\"\n---=== REPLACEMENT ===---\nexport EXTRA_LIBS=\"$EXTRA_LIBS -ljbig -lzstd -L$SRC/install/lib -lwebp -lsharpyuv -llzma -lexpat -L$SRC/install/lib -lsqlite3 -lgif -ljpeg -lpng -lz\"\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\n# poppler related\nexport EXTRA_LIBS=\"$EXTRA_LIBS -L$SRC/install/lib -lpoppler -ljpeg -lfreetype -lfontconfig -lpng\"\n---=== REPLACEMENT ===---\n# poppler related\nexport EXTRA_LIBS=\"$EXTRA_LIBS -L$SRC/install/lib -lpoppler -ljpeg -lfreetype -lfontconfig -lpng -lbrotlidec -lbrotlicommon -lbz2\""})
