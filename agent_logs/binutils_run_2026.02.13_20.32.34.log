urrent directory)\nif [ -d binutils-gdb ]; then\n    # Case 1: Docker build\n    cd binutils-gdb\nelif [ -f configure.ac ]; then\n    # Case 2: Local checkout - we're already in the source directory\n    echo \"Using local checkout at $(pwd)\"\n    # Create symlinks for fuzz_*.c files so cp ../fuzz_*.c works\n    for f in ../fuzz_*.c; do\n        if [ -f \"$f\" ] && [ ! -f \"$(basename \"$f\")\" ]; then\n            ln -sf \"$f\" .\n        fi\n    done\nelse\n    echo \"ERROR: Cannot find binutils source directory\"\n    echo \"Current directory: $(pwd)\"\n    echo \"Contents:\"\n    ls -la\n    exit 1\nfi"})
