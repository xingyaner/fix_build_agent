###########################################################\n./autogen.sh\n./configure PANDOC=false --with-fuzzer=clang --with-ldap=plugin\nmake\n\n# Copy over the fuzzers - look for fuzz targets (but exclude AFL++ tools)\n# First, clean the output directory\nrm -rf $OUT/*\n\n# Find and copy fuzz targets that start with \"fuzz-\"\nfind . -type f -executable -name \"fuzz-*\" -exec cp {} $OUT/ \\;\n\n# Check if we found any fuzz targets\nif [ -z \"$(ls -A $OUT/)\" ]; then\n  echo \"No fuzz targets found. Checking for any executables with 'fuzz' in name...\"\n  # Fallback: look for any executables with \"fuzz\" in name but exclude AFL++ tools\n  find . -type f -executable -name \"*fuzz*\" ! -path \"*/aflplusplus/*\" -exec cp {} $OUT/ \\;\nfi\n\n# Verify we have fuzz targets\nif [ -z \"$(ls -A $OUT/)\" ]; then\n  echo \"ERROR: No fuzz targets found in build output!\"\n  exit 1\nelse\n  echo \"Successfully copied $(ls -1 $OUT/ | wc -l) fuzz target(s) to $OUT/\"\n  ls -la $OUT/\nfi\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/dovecot/Dockerfile\n---=== ORIGINAL ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:b79d3707eeffb6c75a530689b5ade9038bd005628f44d30c62680f4b810c3900\nRUN apt-get update && apt-get install -y make autoconf automake libtool wget gettext automake libxml2-dev m4 pkg-config bison flex python3.8-venv libssl-dev zlib1g-dev libldap2-dev\nRUN git clone  https://github.com/dovecot/core dovecot\nWORKDIR dovecot\nCOPY build.sh $SRC/\n#COPY fuzz-* $SRC/\n---=== REPLACEMENT ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:b79d3707eeffb6c75a530689b5ade9038bd005628f44d30c62680f4b810c3900\nRUN apt-get update && apt-get install -y make autoconf automake libtool wget gettext automake libxml2-dev m4 pkg-config bison flex python3.8-venv libssl-dev zlib1g-dev libldap2-dev\nRUN git clone  https://github.com/dovecot/core dovecot\nWORKDIR dovecot\nCOPY build.sh $SRC/\n#COPY fuzz-* $SRC/\n\n# Set up environment to suppress linker warnings\nENV CFLAGS=\"$CFLAGS -Wno-portability\"\nENV CXXFLAGS=\"$CXXFLAGS -Wno-portability\""})
