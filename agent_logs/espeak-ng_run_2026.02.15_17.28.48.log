\" = \"afl\" ]; then\n    # For AFL++, don't use --with-libfuzzer=yes as it adds libFuzzer-specific flags\n    # that conflict with AFL++ compiler wrapper\n    ./configure --disable-shared --with-speechplayer=no\nelse\n    # For libFuzzer, use the libfuzzer flag\n    ./configure --with-libfuzzer=yes --disable-shared --with-speechplayer=no\nfi\n\nmake check || true\ncp tests/ssml-fuzzer.test $OUT/ssml-fuzzer\ncp -r espeak-ng-data/ $OUT/"})
