MENT ===---\n# Clone libtiff with a specific tag that might work with older autoconf\n# or use a version before the autoconf 2.71 requirement was added\nRUN git clone --depth 1 --branch v4.6.0 https://gitlab.com/libtiff/libtiff.git\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/libvips/Dockerfile\n---=== ORIGINAL ===---\nRUN git clone  https://github.com/google/libultrahdr.git\n\nWORKDIR libvips\nCOPY build.sh $SRC/\n---=== REPLACEMENT ===---\nRUN git clone  https://github.com/google/libultrahdr.git\n\n# Verify autoconf version\nRUN autoconf --version\n\nWORKDIR libvips\nCOPY build.sh $SRC/"})
