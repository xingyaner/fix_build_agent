65328a842b87f\n# Clone to /src/curl to avoid being overwritten by mount\nRUN git clone  https://github.com/curl/curl.git /src/curl && \\\n    cd /src/curl && \\\n    git checkout 517a12922e8a02caf94b70877bf65328a842b87f\n\n# Clone libtiff repository and checkout specific commit 9923b128f448270d34a88357ba9b10e108a3eafb\n# Clone to /src/libtiff to avoid being overwritten by mount\nRUN git clone  https://gitlab.com/libtiff/libtiff.git /src/libtiff && \\\n    cd /src/libtiff && \\\n    git checkout 9923b128f448270d34a88357ba9b10e108a3eafb\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/proj4/Dockerfile\n---=== ORIGINAL ===---\nWORKDIR PROJ\n\n# Fix build.sh before copying: Update to use /src/curl and /src/libtiff instead of PROJ/curl and PROJ/libtiff\nRUN sed -i 's|cd curl|cd /src/curl|g; s|cd libtiff|cd /src/libtiff|g' test/fuzzers/build.sh\n\n# Also add cd $SRC/PROJ before building curl (but curl is now at /src/curl, not in PROJ)\nRUN sed -i '39i# Change to PROJ directory for PROJ build\\ncd $SRC/PROJ' test/fuzzers/build.sh\n\n# Cache busting: Add timestamp to ensure updated build.sh is copied\nRUN echo \"Build timestamp: $(date)\" && cp test/fuzzers/build.sh $SRC/\n---=== REPLACEMENT ===---\nWORKDIR PROJ\n\n# Fix build.sh before copying: Update to use /src/curl and /src/libtiff instead of PROJ/curl and PROJ/libtiff\nRUN sed -i 's|cd curl|cd /src/curl|g; s|cd libtiff|cd /src/libtiff|g' test/fuzzers/build.sh\n\n# Update curl configure command to use OpenSSL 3.0+ at /opt/openssl3\nRUN sed -i 's|./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install|./configure --disable-shared --with-ssl=/opt/openssl3 --without-libpsl --prefix=$SRC/install|g' test/fuzzers/build.sh\n\n# Also add cd $SRC/PROJ before building curl (but curl is now at /src/curl, not in PROJ)\nRUN sed -i '39i# Change to PROJ directory for PROJ build\\ncd $SRC/PROJ' test/fuzzers/build.sh\n\n# Cache busting: Add timestamp to ensure updated build.sh is copied\nRUN echo \"Build timestamp: $(date)\" && cp test/fuzzers/build.sh $SRC/\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd /src/curl\nautoreconf -i\n./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== REPLACEMENT ===---\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd /src/curl\nautoreconf -i\n./configure --disable-shared --with-ssl=/opt/openssl3 --without-libpsl --prefix=$SRC/install\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd .."})
