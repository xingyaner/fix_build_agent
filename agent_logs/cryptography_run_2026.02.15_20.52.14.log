ocal/ssl\nexport OPENSSL_LIBRARIES=/usr/local/ssl/lib\nexport LD_LIBRARY_PATH=/usr/local/ssl/lib:$LD_LIBRARY_PATH\n# Install cryptography with OpenSSL 3.0.13 support\nCFLAGS=\"-I/usr/local/ssl/include\" LDFLAGS=\"-L/usr/local/ssl/lib\" python3 -m pip install .\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/cryptography/Dockerfile\n---=== ORIGINAL ===---\nENV PATH=\"/root/.cargo/bin:${PATH}\"\nRUN rustup install nightly\nRUN rustup default nightly\nWORKDIR cryptography\n---=== REPLACEMENT ===---\nENV PATH=\"/root/.cargo/bin:${PATH}\"\nRUN rustup install nightly\nRUN rustup default nightly\n# Set environment variables for Rust to find OpenSSL\nENV OPENSSL_DIR=/usr/local/ssl\nENV OPENSSL_INCLUDE_DIR=/usr/local/ssl/include\nENV OPENSSL_LIB_DIR=/usr/local/ssl/lib\nWORKDIR cryptography"})
