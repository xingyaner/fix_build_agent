K/build\nrm -rf $build\nmkdir -p $build\n\nexport LIBTPMS=$(pwd)\nautoreconf -vfi\n\ncd $build\n$LIBTPMS/configure --disable-shared --enable-static --with-openssl --with-tpm2\n\n# Copy necessary headers from source to build directory\n# This is needed because generated headers (tpm_library.h) include other headers\n# with relative paths, and they need to be in the same directory\nmkdir -p include/libtpms\ncp -f $LIBTPMS/include/libtpms/*.h include/libtpms/ 2>/dev/null || true\n\nmake -j$(nproc) && make -C tests fuzz\n\nzip -jqr $OUT/fuzz_seed_corpus.zip \"$LIBTPMS/tests/corpus-execute-command\"\n\nfind $build -type f -executable -name \"fuzz*\" -exec mv {} $OUT \\;\nfind $build -type f -name \"*.options\" -exec mv {} $OUT \\;\nEOF\nchmod +x /tmp/modified-oss-fuzz.sh\n\n# Run the modified oss-fuzz.sh\ncd /src/libtpms\n/tmp/modified-oss-fuzz.sh"})
