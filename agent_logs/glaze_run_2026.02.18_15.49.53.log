is file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\n# Add compiler workaround flags for clang-22 template instantiation bug\nexport CXXFLAGS=\"$CXXFLAGS -ftemplate-depth=1024 -fconstexpr-depth=1024 -fconstexpr-steps=1000000\"\n\nfuzzing/ossfuzz.sh\n---=== FILE ===---\n/root/fix_build_agent/process/project/glaze/fuzzing/msgpack_roundtrip_string.cpp\n---=== ORIGINAL ===---\nstruct S\n{\n   std::string value{};\n};\n\nvoid test(const uint8_t* Data, size_t Size)\n{\n   S s{{Data, Data + Size}};\n\n   // MessagePack handles arbitrary byte sequences in strings\n   std::string buffer{};\n   auto write_ec = glz::write_msgpack(s, buffer);\n   if (write_ec) {\n      return;\n   }\n   auto restored = glz::read_msgpack<S>(buffer);\n   assert(restored);\n   assert(restored.value().value == s.value);\n}\n\nextern \"C\" int LLVMFuzzerTestOneInput(const uint8_t* Data, size_t Size)\n{\n   test(Data, Size);\n   return 0;\n}\n---=== REPLACEMENT ===---\nstruct S\n{\n   std::string value{};\n};\n\n// Add missing glz::meta specialization for struct S\ntemplate <>\nstruct glz::meta<S>\n{\n   using T = S;\n   static constexpr auto value = glz::object(\"value\", &T::value);\n};\n\nvoid test(const uint8_t* Data, size_t Size)\n{\n   S s{{Data, Data + Size}};\n\n   // MessagePack handles arbitrary byte sequences in strings\n   std::string buffer{};\n   auto write_ec = glz::write_msgpack(s, buffer);\n   if (write_ec) {\n      return;\n   }\n   auto restored = glz::read_msgpack<S>(buffer);\n   assert(restored);\n   assert(restored.value().value == s.value);\n}\n\nextern \"C\" int LLVMFuzzerTestOneInput(const uint8_t* Data, size_t Size)\n{\n   test(Data, Size);\n   return 0;\n}"})
