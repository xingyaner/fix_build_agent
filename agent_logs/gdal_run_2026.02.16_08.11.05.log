ibwebp-dev${ARCH_SUFFIX} \\\n          libzstd-dev${ARCH_SUFFIX} \\\n          libssl-dev${ARCH_SUFFIX} \\\n          libfreetype6-dev${ARCH_SUFFIX} libfontconfig1-dev${ARCH_SUFFIX} libtiff5-dev${ARCH_SUFFIX} libboost-dev${ARCH_SUFFIX}\n---=== REPLACEMENT ===---\n          libwebp-dev${ARCH_SUFFIX} \\\n          libzstd-dev${ARCH_SUFFIX} \\\n          libfreetype6-dev${ARCH_SUFFIX} libfontconfig1-dev${ARCH_SUFFIX} libtiff5-dev${ARCH_SUFFIX} libboost-dev${ARCH_SUFFIX}\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\nautoreconf -fi\n./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install --with-ssl=/usr/local/ssl\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== REPLACEMENT ===---\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\nautoreconf -fi\n# Set environment variables to ensure curl finds our OpenSSL 3.0\nexport PKG_CONFIG_PATH=/usr/local/ssl/lib/pkgconfig\nexport LDFLAGS=\"-L/usr/local/ssl/lib\"\nexport CPPFLAGS=\"-I/usr/local/ssl/include\"\n./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install --with-ssl=/usr/local/ssl\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\nexport EXTRA_LIBS=\"-Wl,-Bstatic \"\n# curl related\nexport EXTRA_LIBS=\"$EXTRA_LIBS -L$SRC/install/lib -lcurl -lssl -lcrypto -lz\"\n---=== REPLACEMENT ===---\nexport EXTRA_LIBS=\"-Wl,-Bstatic \"\n# curl related\nexport EXTRA_LIBS=\"$EXTRA_LIBS -L$SRC/install/lib -lcurl -L/usr/local/ssl/lib -lssl -lcrypto -lz\"\n"})
