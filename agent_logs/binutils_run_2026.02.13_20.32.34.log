re already in the binutils source directory at /src\n    echo \"Using local checkout at $(pwd)\"\n    # The fuzz_*.c files are at /src, but we need them in the current directory for cp ../fuzz_*.c\n    # So we create symlinks\n    for f in fuzz_*.c; do\n        if [ ! -f \"$f\" ] && [ -f \"../$f\" ]; then\n            ln -sf \"../$f\" .\n        fi\n    done\nelse\n    echo \"ERROR: Cannot find binutils source directory\"\n    echo \"Current directory: $(pwd)\"\n    echo \"Contents:\"\n    ls -la\n    exit 1\nfi"})
