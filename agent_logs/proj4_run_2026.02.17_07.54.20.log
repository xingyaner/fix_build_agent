  - TOOL_CALL: create_or_update_file({"file_path": "solution.txt", "content": "---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/proj4/Dockerfile\n---=== ORIGINAL ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:cede7bc2cc2ece182ffb31a0d118e0e3ade537b2ea40803829f19373815bb8f8\nRUN apt-get update && \\\n    apt-get install -y make autoconf automake libtool g++ sqlite3 pkg-config wget\n\nRUN git clone  https://github.com/OSGeo/PROJ PROJ\n\nRUN git clone  https://github.com/curl/curl.git PROJ/curl\n\nRUN git clone  https://gitlab.com/libtiff/libtiff.git PROJ/libtiff\n\nWORKDIR PROJ\n\nRUN cp test/fuzzers/build.sh $SRC/\n---=== REPLACEMENT ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:cede7bc2cc2ece182ffb31a0d118e0e3ade537b2ea40803829f19373815bb8f8\nRUN apt-get update && \\\n    apt-get install -y make autoconf automake libtool g++ sqlite3 pkg-config wget\n\n# Add cache busting to force rebuild\nARG CACHE_BUST=2025_02_17_01\nRUN echo \"Force rebuild timestamp: $CACHE_BUST\"\n\nRUN git clone  https://github.com/OSGeo/PROJ PROJ\n\n# Clone dependencies to root for predictable paths\nRUN git clone  https://github.com/curl/curl.git /curl\n\nRUN git clone  https://gitlab.com/libtiff/libtiff.git /libtiff\n\nWORKDIR PROJ\n\n# Create a fixed build.sh that handles the directory issue\n# The issue: build.sh runs from /src but expects to be in PROJ directory\n# Solution: Create a wrapper that changes to PROJ first\nRUN cat > /src/build.sh << 'EOF'\n#!/bin/bash\nset -e\n\n# The original build.sh expects to run from PROJ directory\n# But it's executed from /src in the container\n# First, try to find and change to PROJ directory\nif [ -d \"/PROJ\" ]; then\n    cd /PROJ\nelif [ -d \"$SRC/PROJ\" ]; then\n    cd $SRC/PROJ\nelif [ -d \"PROJ\" ]; then\n    cd PROJ\nelse\n    echo \"ERROR: Cannot find PROJ directory\"\n    exit 1\nfi\n\n# Now run the actual build steps\n# Check for curl in multiple locations\nif [ -d \"/curl\" ]; then\n    cd /curl\nelif [ -d \"curl\" ]; then\n    cd curl\nelif [ -d \"/PROJ/curl\" ]; then\n    cd /PROJ/curl\nelif [ -d \"$SRC/PROJ/curl\" ]; then\n    cd $SRC/PROJ/curl\nelse\n    echo \"ERROR: curl directory not found\"\n    exit 1\nfi\nautoreconf -i\n./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n\n# Check for libtiff in multiple locations\nif [ -d \"/libtiff\" ]; then\n    cd /libtiff\nelif [ -d \"libtiff\" ]; then\n    cd libtiff\nelif [ -d \"/PROJ/libtiff\" ]; then\n    cd /PROJ/libtiff\nelif [ -d \"$SRC/PROJ/libtiff\" ]; then\n    cd $SRC/PROJ/libtiff\nelse\n    echo \"ERROR: libtiff directory not found\"\n    exit 1\nfi\n./autogen.sh\n./configure --disable-shared --prefix=$SRC/install\nmake -j$(nproc)\nmake install\ncd ..\n\nmkdir build\ncd build\ncmake .. -DBUILD_SHARED_LIBS:BOOL=OFF \\\n        -DCURL_INCLUDE_DIR:PATH=\"$SRC/install/include\" \\\n        -DCURL_LIBRARY_RELEASE:FILEPATH=\"$SRC/install/lib/libcurl.a\" \\\n        -DTIFF_INCLUDE_DIR:PATH=\"$SRC/install/include\" \\\n        -DTIFF_LIBRARY_RELEASE:FILEPATH=\"$SRC/install/lib/libtiff.a\" \\\n        -DCMAKE_INSTALL_PREFIX=$SRC/install \\\n        -DBUILD_APPS:BOOL=OFF \\\n        -DBUILD_TESTING:BOOL=OFF \\\n        ${PROJ_CMAKE_EXTRA_ARGS}\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n\nEXTRA_LIBS=\"-lpthread -Wl,-Bstatic -lsqlite3 -L$SRC/install/lib -ltiff -lcurl -lssl -lcrypto -lz -Wl,-Bdynamic\"\n\nbuild_fuzzer()\n{\n    fuzzerName=$1\n    sourceFilename=$2\n    shift\n    shift\n    echo \"Building fuzzer $fuzzerName\"\n    $CXX $CXXFLAGS -std=c++11 -fvisibility=hidden -Isrc -Iinclude \\\n        $sourceFilename $* -o $OUT/$fuzzerName \\\n        $LIB_FUZZING_ENGINE \"$SRC/install/lib/libproj.a\" $EXTRA_LIBS\n}\n\nbuild_fuzzer proj_crs_to_crs_fuzzer test/fuzzers/proj_crs_to_crs_fuzzer.cpp\n\necho \"[libfuzzer]\" > $OUT/proj_crs_to_crs_fuzzer.options\necho \"max_len = 10000\" >> $OUT/proj_crs_to_crs_fuzzer.options\n\ncp -r data/* $OUT\nEOF\n\nRUN chmod +x /src/build.sh\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\n#!/bin/bash\n\n# This script is meant to be run by\n# https://github.com/google/oss-fuzz/blob/master/projects/proj.4/Dockerfile\n\nset -e\n\nif [ \"$SRC\" == \"\" ]; then\n    echo \"SRC env var not defined\"\n    exit 1\nfi\n\nif [ \"$OUT\" == \"\" ]; then\n    echo \"OUT env var not defined\"\n    exit 1\nfi\n\nif [ \"$CXX\" == \"\" ]; then\n    echo \"CXX env var not defined\"\n    exit 1\nfi\n\nif [ \"$LIB_FUZZING_ENGINE\" = \"\" ]; then\n    export LIB_FUZZING_ENGINE=-lFuzzingEngine\nfi\n\nI386_PACKAGES=\"zlib1g-dev:i386 libssl-dev:i386 libsqlite3-dev:i386\"\nX64_PACKAGES=\"zlib1g-dev libssl-dev libsqlite3-dev\"\n\nif [ \"$ARCHITECTURE\" = \"i386\" ]; then\n    apt-get install -y $I386_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\" -DSQLite3_LIBRARY=/lib/i386-linux-gnu/libsqlite3.a\"\nelse\n    apt-get install -y $X64_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\"\"\nfi\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\nautoreconf -i\n./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n\n# build libtiff.a\ncd libtiff\n./autogen.sh\n./configure --disable-shared --prefix=$SRC/install\nmake -j$(nproc)\nmake install\ncd ..\n---=== REPLACEMENT ===---\n#!/bin/bash\n\n# This script is meant to be run by\n# https://github.com/google/oss-fuzz/blob/master/projects/proj.4/Dockerfile\n\nset -e\n\nif [ \"$SRC\" == \"\" ]; then\n    echo \"SRC env var not defined\"\n    exit 1\nfi\n\nif [ \"$OUT\" == \"\" ]; then\n    echo \"OUT env var not defined\"\n    exit 1\nfi\n\nif [ \"$CXX\" == \"\" ]; then\n    echo \"CXX env var not defined\"\n    exit 1\nfi\n\nif [ \"$LIB_FUZZING_ENGINE\" = \"\" ]; then\n    export LIB_FUZZING_ENGINE=-lFuzzingEngine\nfi\n\nI386_PACKAGES=\"zlib1g-dev:i386 libssl-dev:i386 libsqlite3-de