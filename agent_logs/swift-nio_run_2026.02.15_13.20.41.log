MENT ===---\n# Build with libfuzzer flags - add static linking and C interop flags\nexport SWIFTFLAGS=\"$SWIFTFLAGS -Xswiftc -parse-as-library -Xswiftc -static-stdlib -Xswiftc -Xlinker -Xswiftc -export-dynamic\"\n. precompile_swift\n# Add explicit Swift version flag if we're using Swift 6\nif [[ \"$CLEAN_SWIFT_VERSION\" == 6.* ]]; then\n    swift build -c debug $SWIFTFLAGS -Xswiftc -swift-version -Xswiftc 6\nelse\n    swift build -c debug $SWIFTFLAGS\nfi\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/swift-nio/Dockerfile\n---=== ORIGINAL ===---\nFROM gcr.io/oss-fuzz-base/base-builder-swift\n\n# specific swift-nio\nRUN git clone  https://github.com/google/fuzzing\nRUN git clone  https://github.com/apple/swift-nio.git\nCOPY build.sh $SRC\nCOPY *.swift $SRC/\nWORKDIR $SRC/swift-nio\n---=== REPLACEMENT ===---\nFROM gcr.io/oss-fuzz-base/base-builder-swift\n\n# specific swift-nio\nRUN git clone  https://github.com/google/fuzzing\nRUN git clone  https://github.com/apple/swift-nio.git\nCOPY build.sh $SRC\nCOPY *.swift $SRC/\nWORKDIR $SRC/swift-nio\n\n# Ensure we have the latest Swift toolchain\nRUN apt-get update && apt-get install -y swift swift-doc"})
