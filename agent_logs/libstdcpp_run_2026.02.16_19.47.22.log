 $( echo $INSTALLDIR/include/c++/*/ ) \\\n\t-cxx-isystem $( echo $INSTALLDIR/include/c++/*/x86_64-pc-linux-gnu ) \\\n\t$fuzzsrcfile \\\n\t-o $OUT/$targetfile \\\n\t$LIB_FUZZING_ENGINE \\\n\t$LIBSTDCPP_A\ndone"})
