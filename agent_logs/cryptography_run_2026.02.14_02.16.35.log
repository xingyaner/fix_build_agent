l --openssldir=/usr/local/ssl shared zlib && \\\n    make && \\\n    make install && \\\n    echo \"/usr/local/ssl/lib64\" >> /etc/ld.so.conf.d/openssl-3.0.9.conf && \\\n    ldconfig && \\\n    cd .. && \\\n    rm -rf openssl-3.0.9 openssl-3.0.9.tar.gz\n# Set environment variables with proper default values\nENV LD_LIBRARY_PATH=\"/usr/local/ssl/lib64\"\nENV PKG_CONFIG_PATH=\"/usr/local/ssl/lib64/pkgconfig\"\nRUN pip3 install --upgrade pip\nRUN curl https://sh.rustup.rs -sSf | sh -s -- -y\n\nENV PATH=\"/root/.cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\nRUN rustup install nightly\nRUN rustup default nightly\nWORKDIR cryptography\n\nCOPY build.sh fuzz_*.py $SRC/\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/cryptography/build.sh\n---=== ORIGINAL ===---\npython3 -m pip cache purge\n# Compiling with sancov is causing some issues at the moment. This is likely\n# due to some missing flags propagated throughout.\nunset RUSTFLAGS\nunset CXXFLAGS\nunset CFLAGS\n# Set OpenSSL environment variables for building\nexport LD_LIBRARY_PATH=\"/usr/local/ssl/lib64:${LD_LIBRARY_PATH}\"\nexport PKG_CONFIG_PATH=\"/usr/local/ssl/lib64/pkgconfig:${PKG_CONFIG_PATH}\"\npython3 -m pip install .\n\ncd $SRC\nfor fuzzer in $(find $SRC -name 'fuzz_*.py'); do\n   compile_python_fuzzer $fuzzer \ndone\n---=== REPLACEMENT ===---\npython3 -m pip cache purge\n# Compiling with sancov is causing some issues at the moment. This is likely\n# due to some missing flags propagated throughout.\nunset RUSTFLAGS\nunset CXXFLAGS\nunset CFLAGS\n# Set OpenSSL environment variables for building with proper default values\nexport LD_LIBRARY_PATH=\"/usr/local/ssl/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}\"\nexport PKG_CONFIG_PATH=\"/usr/local/ssl/lib64/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}\"\npython3 -m pip install .\n\ncd $SRC\nfor fuzzer in $(find $SRC -name 'fuzz_*.py'); do\n   compile_python_fuzzer $fuzzer \ndone"})
