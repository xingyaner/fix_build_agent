elif make -n build/libsign.so 2>/dev/null; then\n    echo \"Building build/libsign.so...\"\n    make -j$(nproc) build/libsign.so\nelif make -n all 2>/dev/null; then\n    echo \"Building all targets...\"\n    make -j$(nproc) all\n    # Look for the library file after build\n    if [ -f \"libsign.a\" ]; then\n        echo \"Found libsign.a\"\n    elif [ -f \"build/libsign.a\" ]; then\n        echo \"Found build/libsign.a\"\n    elif [ -f \"src/libsign.a\" ]; then\n        echo \"Found src/libsign.a\"\n    fi\nelse\n    # Try to build with default target\n    echo \"Building with default target...\"\n    make -j$(nproc)\nfi\n\n# Check if library was built and set LIBECC_PATH\nif [ -f \"libsign.a\" ]; then\n    export LIBECC_PATH=$(realpath .)\nelif [ -f \"build/libsign.a\" ]; then\n    export LIBECC_PATH=$(realpath .)\nelif [ -f \"src/libsign.a\" ]; then\n    export LIBECC_PATH=$(realpath .)\nelse\n    # Try to find any libsign.* file\n    LIB_FILE=$(find . -name \"libsign.*\" -type f | head -1)\n    if [ -n \"$LIB_FILE\" ]; then\n        echo \"Found library: $LIB_FILE\"\n        export LIBECC_PATH=$(dirname $(realpath \"$LIB_FILE\"))\n    else\n        echo \"Warning: Could not find libsign library, continuing anyway...\"\n        export LIBECC_PATH=$(realpath .)\n    fi\nfi\n\nexport CXXFLAGS=\"$CXXFLAGS -DCRYPTOFUZZ_LIBECC\"\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/libecc/build.sh\n---=== ORIGINAL ===---\n# Ensure libecc has the necessary directory structure\ncd $SRC/libecc\nmkdir -p src/curves\n\n# Build libecc\n---=== REPLACEMENT ===---\n# Ensure libecc has the necessary directory structure\ncd $SRC/libecc\nmkdir -p src/curves\n\n# Check libecc Makefile to understand build system\nif [ -f \"Makefile\" ]; then\n    echo \"Libecc Makefile targets:\"\n    grep -E \"^[a-zA-Z0-9_-]+:\" Makefile | head -20\nfi\n\n# Build libecc\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/libecc/build.sh\n---=== ORIGINAL ===---\nexport CXXFLAGS=\"$CX