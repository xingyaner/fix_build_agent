l_llvm --features=universal,llvm -O\ncargo $nightly fuzz build universal_singlepass --features=universal,singlepass -O\ncargo $nightly fuzz build metering --features=universal,cranelift -O\ncargo $nightly fuzz build deterministic --features=universal,cranelift,llvm,singlepass -O\n\nfuzz_targets="universal_cranelift \\\n  universal_llvm \\\n  universal_singlepass \\\n  metering \\\n  deterministic"\nfuzz_target_output_dir=target/x86_64-unknown-linux-gnu/release\n\nfor target in $fuzz_targets; do\n\tcp $fuzz_target_output_dir/$target $OUT/\n\tcp $SRC/default.options $OUT/$target.options\ndone\n\n### Content from: default.options ###\n[libfuzzer]\ndetect_leaks=0\n\n### Content from: project.yaml ###\nbase_os_version: ubuntu-24-04\nhomepage: "https://github.com/wasmerio/wasmer"\nlanguage: rust\nmain_repo: "https://github.com/wasmerio/wasmer"\nprimary_contact: "edoardo@wasmer.io"\nauto_ccs:\n  - syrus@wasmer.io\n  - christoph@wasmer.io\n  - amin@wasmer.io\nsanitizers:\n  - address\nfuzzing_engines:\n  - libfuzzer\nvendor_ccs:\n  - maxnair.dev@gmail.com\ncoverage_extra_args: >\n  -ignore-filename-regex=.*/rustc/.*\n\n--- Project File Tree (Shallow View) ---\n📁 wasmer\n├── 📄 CHANGELOG.md\n├── 📄 Cargo.lock\n├── 📄 Cargo.toml\n├── 📄 LICENSE\n├── 📄 Makefile\n├── 📄 README.md\n├── 📁 assets\n├── 📁 benches\n├── 📄 build.rs\n├── 📄 deny.toml\n├── 📁 docs\n├── 📁 examples\n├── 📄 flake.lock\n├── 📄 flake.nix\n├── 📁 fuzz\n├── 📁 lib\n├── 📄 rust-toolchain\n├── 📁 scripts\n└── 📁 tests\n\n--- Recent Commit Changes ---\nNo relevant commit found.\n\n--- Fuzz Build Log (Last 500 lines) ---\nINFO:common_utils:Running: docker build -t gcr.io/oss-fuzz/wasmer --file /root/fix_build_agent/oss-fuzz/projects/wasmer/Dockerfile /root/fix_build_agent/oss-fuzz/projects/wasmer.\n#0 building with "default" instance using docker driver\n\n#1 [internal] load build definition from Dockerfile\n#1 transferring dockerfile: 1.35kB done\n#1 WARN: InvalidDefaultArgInFrom: Default value for ARG gcr.io/oss-fuzz-base/base