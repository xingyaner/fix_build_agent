n\n    apt-get install -y $I386_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\" -DSQLite3_LIBRARY=/lib/i386-linux-gnu/libsqlite3.a\"\nelse\n    apt-get install -y $X64_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\"\"\nfi\n\n# Debug: Print current directory and check if PROJ exists\necho \"Current directory: $(pwd)\"\necho \"SRC: $SRC\"\necho \"Checking if $SRC/PROJ exists:\"\nls -la $SRC/PROJ/ 2>/dev/null || echo \"PROJ directory not found at $SRC/PROJ\"\n\n# Change to PROJ directory where curl and libtiff are located\ncd $SRC/PROJ\necho \"Changed to PROJ directory: $(pwd)\"\necho \"Contents of PROJ directory:\"\nls -la\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\n---=== REPLACEMENT ===---\nif [ \"$ARCHITECTURE\" = \"i386\" ]; then\n    apt-get install -y $I386_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\" -DSQLite3_LIBRARY=/lib/i386-linux-gnu/libsqlite3.a\"\nelse\n    apt-get install -y $X64_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\"\"\nfi\n\n# Change to PROJ directory where curl and libtiff are located\ncd $SRC/PROJ\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl"})
