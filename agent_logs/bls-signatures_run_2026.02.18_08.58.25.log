without overwriting Makefile's CXXFLAGS\n        make CXXFLAGS+=\" -Wno-deprecated-literal-operator\"\n    else\n        rustup target add i686-unknown-linux-gnu\n        make -f Makefile-i386 CXXFLAGS+=\" -Wno-deprecated-literal-operator\"\n    fi\n    export CXXFLAGS=\"$CXXFLAGS -DCRYPTOFUZZ_ARKWORKS_ALGEBRA\"\nfi\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/bls-signatures/build.sh\n---=== ORIGINAL ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\nmake -B -j\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures\n---=== REPLACEMENT ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\n# Append warning suppression flag without overwriting Makefile's CXXFLAGS\nmake -B -j CXXFLAGS+=\" -Wno-deprecated-literal-operator\"\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/bls-signatures/build.sh\n---=== ORIGINAL ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\nrm entry.o; make\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures_optimize_size\n---=== REPLACEMENT ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\n# Append warning suppression flag without overwriting Makefile's CXXFLAGS\nrm entry.o; make CXXFLAGS+=\" -Wno-deprecated-literal-operator\"\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures_optimize_size"})
