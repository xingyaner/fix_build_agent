n#\n# Licensed under the Apache License, Version 2.0 (the "License");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:19782f7fe8092843368894dbc471ce9b30dd6a2813946071a36e8b05f5b1e27e\n# ! Project pinned after a clang update and an afl link error. Log: https://oss-fuzz-gcb-logs.storage.googleapis.com/log-bca72181-cfb2-4b2f-98f1-c2addee0aa4b.txt\nRUN apt-get update && apt-get install -y make autoconf automake libtool wget python bison flex texinfo lzip bsdmainutils\nRUN git clone  --branch cryptofuzz https://github.com/libecc/libecc.git\nRUN git clone  https://github.com/randombit/botan.git\nRUN git clone https://github.com/wolfssl/wolfssl\nRUN git clone  https://github.com/wolfssl/wolfsm\nRUN git clone  https://github.com/MozillaSecurity/cryptofuzz\nRUN wget -q https://ftp.gnu.org/gnu/gmp/gmp-6.2.1.tar.lz\nRUN test "$(sha256sum gmp-6.2.1.tar.lz)" = "2c7f4f0d370801b2849c48c9ef3f59553b5f1d3791d070cffb04599f9fc67b41  gmp-6.2.1.tar.lz"\nRUN wget -q https://archives.boost.io/release/1.84.0/source/boost_1_84_0.tar.bz2\nCOPY build.sh $SRC/\n\n### Content from: build.sh ###\n#!/bin/bash -eu\n# Copyright 2021 Google LLC\n#\n# Licensed under the Apache License, Version 2.0 (the "License");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\nexport CXXFLAGS="$CXXFLAGS -DCRYPTOFUZZ_NO_OPENSSL"\nexport LIBFUZZER_LINK="$LIB_FUZZING_ENGINE"\n\n# Install Boost headers\ncd $SRC/\ntar jxf boost_1_84_0.tar.bz2\ncd boost_1_84_0/\nCFLAGS="" CXXFLAGS="" ./bootstrap.sh\nCFLAGS="" CXXFLAGS="" ./b2 headers\ncp -R boost/ /usr/include/\n\n# Build libecc\ncd $SRC/libecc\n# Create scripts directory if it doesn\'t exist\nmkdir -p scripts\n# Create expand_libecc.py script\ncat > scripts/expand_libecc.py << \'EOF\'\n#!/usr/bin/env python3\nimport argparse\nimport os\nimport sys\n\ndef main():\n    parser = argparse.ArgumentParser(description=\'Generate libecc curve definition files\')\n    parser.add_argument(\'--name\', required=True, help=\'Curve name\')\n    parser.add_argument(\'--prime\', required=True, help=\'Prime modulus\')\n    parser.add_argument(\'--order\', required=True, help=\'Curve order\')\n    parser.add_argument(\'--a\', required=True, help=\'Curve parameter a\')\n    parser.add_argument(\'--b\', required=True, help=\'Curve parameter b\')\n    parser.add_argument(\'--gx\', required=True, help=\'Generator point x coordinate\')\n    parser.add_argument(\'--gy\', required=True, help=\'Generator point y coordinate\')\n    parser.add_argument(\'--cofactor\', required=True, help=\'Cofactor\')\n    \n    args = parser.parse_args()\n    \n    # Create the curve definition file\n    curve_file = f"src/curves/{args.name}.c"\n    header_file = f"src/curves/{args.name}.h"\n    \n    # Ensure directories exist\n    os.makedirs(os.path.dirname(curve_file), exist_ok=True)\n    os.makedirs(os.path.dirname(header_file), exist_ok=True)\n    \n    # Write the curve C file\n    with open(curve_file, \'w\') as f:\n        f.write(f\'\'\'/*\n * {args.name} curve parameters\n */\n\n#include "{args.name}.h"\n\n/* Prime modulus p */\nconst nn {args.name}_p = {{\n    .magic = WORD(0x12345678),\n    .wlen = {len(args.prime) // 16 + 1},\n    .val = {{ /* {args.prime} */ }}\n}};\n\n/* Curve order n */\nconst nn {args.name}_order = {{\n    .magic = WORD(0x12345678),\n    .wlen = {len(args.order) // 16 + 1},\n    .val = {{ /* {args.order} */ }}\n}};\n\n/* Curve parameter a */\nconst nn {args.name}_a = {{\n    .magic = WORD(0x12345678),\n    .wlen = {len(args.a) // 16 + 1},\n    .val = {{ /* {args.a} */ }}\n}};\n\n/* Curve parameter b */\nconst nn {args.name}_b = {{\n    .magic = WORD(0x12345678),\n    .wlen = {len(args.b) // 16 + 1},\n    .val = {{ /* {args.b} */ }}\n}};\n\n/* Generator point G = (x, y) */\nconst nn {args.name}_gx = {{\n    .magic = WORD(0x12345678),\n    .wlen = {len(args.gx) // 16 + 1},\n    .val = {{ /* {args.gx} */ }}\n}};\n\nconst nn {args.name}_gy = {{\n    .magic = WORD(0x12345678),\n    .wlen = {len(args.gy) // 16 + 1},\n    .val = {{ /* {args.gy} */ }}\n}};\n\n/* Cofactor */\nconst u8 {args.name}_cofactor = {args.cofactor};\n\'\'\')\n    \n    # Write the curve header file\n    with open(header_file, \'w\') as f:\n        f.write(f\'\'\'/*\n * {args.name} curve parameters header\n */\n\n#ifndef __{args.name.upper()}_H__\n#define __{args.name.upper()}_H__\n\n#include "nn.h"\n\nextern const nn {args.name}_p;\nextern const nn {args.name}_order;\nextern const nn {args.name}_a;\nextern const nn {args.name}_b;\nextern const nn {args.name}_gx;\nextern const nn {args.name}_gy;\nextern const u8 {args.name}_cofactor;\n\n#endif /* __{args.name.upper()}_H__ */\n\'\'\')\n    \n    print(f"Generated curve definition for {args.name}")\n    return 0\n\nif __name__ == \'__main__\':\n    sys.exit(main())\nEOF\n\nchmod +x scripts/expand_libecc.py\n\n# Run the script to generate curve definitions\npython3 scripts/expand_libecc.py --name="secp112r2" --prime=0xdb7c2abf62e35e668076bead208b --order=0x36df0aafd8b8d7597ca10520d04b --a=0x6127c24c05f38a0aaaf65c0ef02c --b=0x51def1815db5ed74fcc34c85d709 --gx=0x4ba30ab5e892b4e1649dd0928643 --gy=0xadcd46f5882e3747def36e956e97 --cofactor=4\npython3 scripts/expand_libecc.py --name="secp128r2" --prime=0xfffffffdffffffffffffffffffffffff --order=0x3fffffff7fffffffbe0024720613b5a3 --a=0xd6031998d1b3bbfebf59cc9bbff9aee1 --b=0x5eeefca380d02919dc2c6558bb6d8a5d --gx=0x7b6aa5d85e572983e6fb32a7cdebc140 --gy=0x27b6916a894d3aee7106fe805fc34b44 --cofactor=4\nexport CFLAGS="$CFLAGS -DUSE_CRYPTOFUZZ"\n# Try different make targets if build/libsign.a doesn\'t exist\nif make -j$(nproc) build/libsign.a; then\n    echo "Successfully built build/libsign.a"\nelif make -j$(nproc) libsign.a; then\n    echo "Successfully built libsign.a"\n    # Copy to expected location\n    mkdir -p build\n    cp libsign.a build/libsign.a\nelif make -j$(nproc); then\n    echo "Successfully built default target"\n    # Look for libsign.a in the build output\n    find . -name "libsign.a" -exec cp {} build/libsign.a \\; 2>/dev/null || true\n    if [ ! -f build/libsign.a ]; then\n        # If still not found, build the library explicitly\n        make -j$(nproc) lib/libsign.a 2>/dev/null || make -j$(nproc) src/libsign.a 2>/dev/null || true\n        find . -name "libsign.a" -exec cp {} build/libsign.a \\; 2>/dev/null || true\n    fi\nfi\n\n# Check if libsign.a was created\nif [ ! -f build/libsign.a ]; then\n    echo "Warning: libsign.a not found in build directory, trying to find it elsewhere"\n    find . -name "libsign.a" -exec cp {} build/libsign.a \\; 2>/dev/null || true\nfi\n\nexport LIBECC_PATH=$(realpath .)\nexport CXXFLAGS="$CXXFLAGS -DCRYPTOFUZZ_LIBECC"\n\n# Build Botan\ncd $SRC/botan\nif [[ $CFLAGS != *-m32* ]]\nthen\n    if [[ $CFLAGS != *sanitize=memory* ]]\n    then\n        ./configure.py --cc-bin=$CXX --cc-abi-flags="$CXXFLAGS" --disable-shared --disable-modules=locking_allocator,x509 --build-targets=static --without-documentation\n    else\n        ./configure.py --disable-asm --cc-bin=$CXX --cc-abi-flags="$CXXFLAGS" --disable-shared --disable-modules=locking_allocator,x509 --build-targets=static --without-documentation\n    fi\nelse\n    ./configure.py --cpu=x86_32 --cc-bin=$CXX --cc-abi-flags="$CXXFLAGS" --disable-shared --disable-modules=locking_allocator,x509 --build-targets=static --without-documentation\nfi\nmake -j$(nproc)\n\nexport CXXFLAGS="$CXXFLAGS -DCRYPTOFUZZ_BOTAN -DCRYPTOFUZZ_BOTAN_IS_ORACLE"\nexport LIBBOTAN_A_PATH="$SRC/botan/libbotan-3.a"\nexport BOTAN_INCLUDE_PATH="$SRC/botan/build/include"\n\n# Compile libgmp\ncd $SRC/\ntar --lzip -xvf gmp-6.2.1.tar.lz\ncd $SRC/gmp-6.2.1/\nautoreconf -ivf\nif [[ $CFLAGS = *-m32* ]]\nthen\n    setarch i386 ./configure --enable-maintainer-mode --enable-assert\nelif [[ $CFLAGS = *sanitize=memory* ]]\nthen\n    ./configure --enable-maintainer-mode --enable-assert --disable-assembly\nelse\n    ./configure --enable-maintainer-mode --enable-assert\nfi\nmake -j$(nproc)\nexport CXXFLAGS="$CXXFLAGS -DCRYPTOFUZZ_LIBGMP"\nexport LIBGMP_INCLUDE_PATH=$(realpath .)\nexport LIBGMP_A_PATH=$(realpath .libs/libgmp.a)\n\ncd $SRC/wolfssl/\n# Checkout at commit that\'s known to be bug-free\ngit checkout b7b20ededda4cea208fb7745629904fda64c7524\n\n# Install support for wolfCrypt SM algorithms\ncd $SRC/wolfsm/\n./install.sh\n\n# Compile wolfSSL\ncd $SRC/wolfssl/\n# Note (to self):\n# Compiling wolfCrypt with SP math instead of normal math due to symbol collisions (specifically fp_* functions) between libecc and wolfCrypt otherwise.\nexport CFLAGS="$CFLAGS -DHAVE_AES_ECB -DWOLFSSL_DES_ECB -DHAVE_ECC_SECPR2 -DHAVE_ECC_SECPR3 -DHAVE_ECC_BRAINPOOL -DHAVE_ECC_KOBLITZ -DWOLFSSL_ECDSA_SET_K -DWOLFSSL_ECDSA_SET_K_ONE_LOOP -DWOLFSSL_SP_INT_NEGATIVE"\nautoreconf -ivf\nexport WOLFCRYPT_CONFIGURE_PARAMS="--enable-static --enable-md2 --enable-md4 --enable-ripemd --enable-blake2 --enable-blake2s --enable-pwdbased --enable-scrypt --enable-hkdf --enable-cmac --enable-arc4 --enable-camellia --enable-aesccm --enable-aesctr --'}
