4 ++++\n 1 file changed, 4 insertions(+)\n\ndiff --git a/CMakeLists.txt b/CMakeLists.txt\nindex 76b143953..a99342488 100644\n--- a/CMakeLists.txt\n+++ b/CMakeLists.txt\n@@ -403,11 +403,15 @@ check_symbol_exists(strlcpy string.h HAVE_STRLCPY)\n check_symbol_exists(strsignal string.h HAVE_STRSIGNAL)\n check_symbol_exists(sysinfo sys/sysinfo.h HAVE_SYSINFO)\n check_symbol_exists(prctl "sys/prctl.h" HAVE_PRCTL)\n+\n+# Test for Processing Unit support in hwloc\n if(TS_USE_HWLOC)\n+  list(APPEND CMAKE_REQUIRED_INCLUDES ${hwloc_INCLUDE_DIRS})\n   check_source_compiles(\n     C "#include <hwloc.h>\n     int main() { return HWLOC_OBJ_PU; }" HAVE_HWLOC_OBJ_PU\n   )\n+  list(REMOVE_ITEM CMAKE_REQUIRED_INCLUDES ${hwloc_INCLUDE_DIRS})\n endif()\n \n check_symbol_exists(SO_TXTIME "sys/socket.h" SO_TXTIME_FOUND)\n\n\n--- Fuzz Build Log (Last 500 lines) ---\nINFO:common_utils:Running: docker build -t gcr.io/oss-fuzz/espeak-ng --file /root/fix_build_agent/oss-fuzz/projects/espeak-ng/Dockerfile /root/fix_build_agent/oss-fuzz/projects/espeak-ng.\n#0 building with "default" instance using docker driver\n\n#1 [internal] load build definition from Dockerfile\n#1 transferring dockerfile: 979B done\n#1 DONE 0.0s\n\n#2 [internal] load metadata for gcr.io/oss-fuzz-base/base-builder@sha256:c099d3d710d12d5d9a39498463ff10973977d1c7a85e9a0fbe00c7f0a0fa9fb8\n#2 DONE 0.7s\n\n#3 [internal] load .dockerignore\n#3 transferring context: 2B done\n#3 DONE 0.0s\n\n#4 [1/5] FROM gcr.io/oss-fuzz-base/base-builder@sha256:c099d3d710d12d5d9a39498463ff10973977d1c7a85e9a0fbe00c7f0a0fa9fb8\n#4 DONE 0.0s\n\n#5 [internal] load build context\n#5 transferring context: 940B done\n#5 DONE 0.0s\n\n#6 [3/5] RUN git clone  https://github.com/espeak-ng/espeak-ng\n#6 CACHED\n\n#7 [4/5] COPY build.sh /src\n#7 CACHED\n\n#8 [2/5] RUN apt-get update && apt install -y automake autoconf libtool pkg-config\n#8 CACHED\n\n#9 [5/5] WORKDIR /src/espeak-ng\n#9 CACHED\n\n#10 exporting to image\n#10 exporting layers done\n#10 writing im