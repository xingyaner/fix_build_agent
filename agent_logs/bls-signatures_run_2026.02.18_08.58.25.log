gs while adding warning suppression\n        make CXXFLAGS=\"$CXXFLAGS -Wno-deprecated-literal-operator\" CXX=\"$CXX\"\n    else\n        rustup target add i686-unknown-linux-gnu\n        make -f Makefile-i386 CXXFLAGS=\"$CXXFLAGS -Wno-deprecated-literal-operator\" CXX=\"$CXX\"\n    fi\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/bls-signatures/build.sh\n---=== ORIGINAL ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\n# Add flag to suppress deprecated literal operator warning in json.hpp\nmake -B -j CXXFLAGS=\"$CXXFLAGS -Wno-deprecated-literal-operator\"\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures\n---=== REPLACEMENT ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\n# Add flag to suppress deprecated literal operator warning in json.hpp\n# Preserve existing Makefile flags while adding warning suppression\nmake -B -j CXXFLAGS=\"$CXXFLAGS -Wno-deprecated-literal-operator\" CXX=\"$CXX\"\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/bls-signatures/build.sh\n---=== ORIGINAL ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\n# Add flag to suppress deprecated literal operator warning in json.hpp\nrm entry.o; make CXXFLAGS=\"$CXXFLAGS -Wno-deprecated-literal-operator\"\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures_optimize_size\n---=== REPLACEMENT ===---\n# Build Cryptofuzz\ncd $SRC/cryptofuzz/\n# Add flag to suppress deprecated literal operator warning in json.hpp\n# Preserve existing Makefile flags while adding warning suppression\nrm entry.o; make CXXFLAGS=\"$CXXFLAGS -Wno-deprecated-literal-operator\" CXX=\"$CXX\"\n\ncp cryptofuzz $OUT/cryptofuzz-bls-signatures_optimize_size"})
