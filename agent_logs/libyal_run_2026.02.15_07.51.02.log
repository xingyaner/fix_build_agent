.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:81c0c136cda1ba3f85fd41f65851f7feb942a5fc0aeca4c4f02fb53fa5e835d8\n\nRUN apt-get update && apt-get install -y make autoconf automake autopoint libtool pkg-config flex byacc\n\nRUN git clone  https://github.com/libyal/libcaes.git libcaes\nRUN git clone  https://github.com/libyal/libfcrypto.git libfcrypto\nRUN git clone  https://github.com/libyal/libfmapi.git libfmapi\nRUN git clone  https://github.com/libyal/libfmos.git libfmos\nRUN git clone  https://github.com/libyal/libfplist.git libfplist\nRUN git clone  https://github.com/libyal/libftxf.git libftxf\nRUN git clone  https://github.com/libyal/libfusn.git libfusn\nRUN git clone  https://github.com/libyal/libfwevt.git libfwevt\nRUN git clone  https://github.com/libyal/libfwnt.git libfwnt\nRUN git clone  https://github.com/libyal/libfwps.git libfwps\nRUN git clone  https://github.com/libyal/libfwsi.git libfwsi\nRUN git clone  https://github.com/libyal/libhmac.git libhmac\n\nRUN git clone  https://github.com/libyal/libagdb.git libagdb\nRUN git clone  https://github.com/libyal/libcreg.git libcreg\nRUN git clone  https://github.com/libyal/libesedb.git libesedb\nRUN git clone  https://github.com/libyal/libevt.git libevt\nRUN git clone  https://github.com/libyal/libevtx.git libevtx\nRUN git clone  https://github.com/libyal/libexe.git libexe\nRUN git clone  https://github.com/libyal/liblnk.git liblnk\nRUN git clone  https://github.com/libyal/libmdmp.git libmdmp\nRUN git clone  https://github.com/libyal/libmsiecf.git libmsiecf\nRUN git clone  https://github.com/libyal/libnk2.git libnk2\nRUN git clone  https://github.com/libyal/libolecf.git libolecf\nRUN git clone  https://github.com/libyal/libpff.git libpff\nRUN git clone  https://github.com/libyal/libregf.git libregf\nRUN git clone  https://github.com/libyal/libscca.git libscca\n\nRUN git clone  https://github.com/libyal/libwrc.git libwrc\n\nRUN git clone  https://github.com/libyal/libfsapfs.git libfsapfs\nRUN git clone  https://github.com/libyal/libfsext.git libfsext\nRUN git clone  https://github.com/libyal/libfsfat.git libfsfat\nRUN git clone  https://github.com/libyal/libfshfs.git libfshfs\nRUN git clone  https://github.com/libyal/libfsntfs.git libfsntfs\nRUN git clone  https://github.com/libyal/libfsxfs.git libfsxfs\n\nRUN git clone  https://github.com/libyal/libbde.git libbde\nRUN git clone  https://github.com/libyal/libfvde.git libfvde\nRUN git clone  https://github.com/libyal/libluksde.git libluksde\nRUN git clone  https://github.com/libyal/libvsapm.git libvsapm\nRUN git clone  https://github.com/libyal/libvsbsdl.git libvsbsdl\nRUN git clone  https://github.com/libyal/libvsgpt.git libvsgpt\nRUN git clone  https://github.com/libyal/libvshadow.git libvshadow\nRUN git clone  https://github.com/libyal/libvslvm.git libvslvm\nRUN git clone  https://github.com/libyal/libvsmbr.git libvsmbr\n\nRUN git clone  https://github.com/libyal/libewf.git libewf\nRUN git clone  https://github.com/libyal/libmodi.git libmodi\nRUN git clone  https://github.com/libyal/libodraw.git libodraw\nRUN git clone  https://github.com/libyal/libphdi.git libphdi\nRUN git clone  https://github.com/libyal/libqcow.git libqcow\nRUN git clone  https://github.com/libyal/libsmraw.git libsmraw\nRUN git clone  https://github.com/libyal/libvhdi.git libvhdi\nRUN git clone  https://github.com/libyal/libvmdk.git libvmdk\n\nWORKDIR libyal\nCOPY build.sh $SRC/\n\n### Content from: build.sh ###\n#!/bin/bash -eu\n# Copyright 2020 Google Inc.\n#\n# Licensed under the Apache License, Version 2.0 (the "License");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an "AS IS" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\nfor PROJECT in ${SRC}/*;\ndo\n  PROJECT=$(basename ${PROJECT})\n\n  # A libyal project should have an ossfuzz directory and a synclibs.sh script.\n  if ! test -d ${SRC}/${PROJECT}/ossfuzz || ! test -x ${SRC}/${PROJECT}/synclibs.sh;\n  then\n    continue\n  fi\n  cd ${SRC}/${PROJECT}\n\n  # OSSFuzz base-image currently uses Ubuntu 20.04 which ships older versions\n  # of autoconf and gettext. The libyal projects are compatible with these\n  # older versions, but should not ship with them. The following edits will\n  # allow ./autogen.sh to generate the correct version for OSSFuzz.\n  sed \'s/^AC_PREREQ.*$/AC_PREREQ([2.69])/\' -i configure.ac\n  sed \'s/^AM_GNU_GETTEXT_VERSION.*$/AM_GNU_GETTEXT_VERSION([0.19])/\' -i configure.ac\n\n  # Prepare the project source for build.\n  ./synclibs.sh\n  ./autogen.sh\n  # OSSFuzz cross-compiles certain architectures which can lead to a partial\n  # installed dependencies.\n  ./configure --enable-shared=no --with-openssl=no --with-zlib=no\n\n  # Build the project and fuzzer binaries.\n  make -j$(nproc) LIB_FUZZING_ENGINE=${LIB_FUZZING_ENGINE}\n\n  # Download the test data if supported.\n  if test -x ./synctestdata.sh;\n  then\n    ./synctestdata.sh\n  fi\n\n  # Copy the fuzzer binaries and test data to the output directory.\n  for FUZZ_TARGET in $(cd ossfuzz && find . -executable -type f);\n  do\n    FUZZ_TARGET=$(basename ${FUZZ_TARGET})\n\n    # Prefix the fuzzer binaries with the project name.\n    cp ossfuzz/${FUZZ_TARGET} ${OUT}/${PROJECT}_${FUZZ_TARGET}\n\n    # Download the test data if supported.\n    LIBYAL_TYPE_NAME=${FUZZ_TARGET/_fuzzer/};\n\n    if test -f tests/data/${LIBYAL_TYPE_NAME/}.1;\n    then\n      (cd tests/data && zip ${OUT}/${PROJECT}_${FUZZ_TARGET}_seed_corpus.zip ${LIBYAL_TYPE_NAME}.*)\n\n    elif test -d tests/input/public;\n    then\n      (cd tests/input/public && zip ${OUT}/${PROJECT}_${FUZZ_TARGET}_seed_corpus.zip *)\n\n    else\n      echo "Missing test data for seed corpus."\n      exit 1\n    fi\n  done\ndone\n\n### Content from: project.yaml ###\nhomepage: "https://github.com/libyal"\nlanguage: c\nprimary_contact: "joachim.metz@gmail.com"\nsanitizers:\n- address\n- memory\n- undefined\narchitectures:\n- x86_64\n- i386\nmain_repo: \'https://github.com/libyal/libfplist.git\'\n\nfuzzing_engines:\n  - afl\n  - honggfuzz\n  - libfuzzer\n\n\n\n--- Project File Tree (Shallow View) ---\n📁 libyal\n├── 📄 ABOUT-NLS\n├── 📄 AUTHORS\n├── 📄 COPYING\n├── 📄 COPYING.LESSER\n├── 📄 ChangeLog\n├── 📄 INSTALL\n├── 📄 Makefile\n├── 📄 Makefile.am\n├── 📄 Makefile.in\n├── 📄 NEWS\n├── 📄 README\n├── 📄 acinclude.m4\n├── 📄 aclocal.m4\n├── 📄 appveyor.yml\n├── 📄 autogen.ps1\n├── 📄 autogen.sh\n├── 📁 autom4te.cache\n├── 📄 build.ps1\n├── 📁 common\n├── 📄 compile\n├── 📄 config.guess\n├── 📄 config.log\n├── 📄 config.rpath\n├── 📄 config.status\n├── 📄 config.sub\n├── 📄 configure\n├── 📄 configure.ac\n├── 📄 depcomp\n├── 📁 documentation\n├── 📁 dpkg\n├── 📄 dtfabric.yaml\n├── 📁 include\n├── 📄 install-sh\n├── 📁 jpff\n├── 📁 libbfio\n├── 📁 libcdata\n├── 📁 libcerror\n├── 📁 libcfile\n├── 📁 libclocale\n├── 📁 libcnotify\n├── 📁 libcpath\n├── 📁 libcsplit\n├── 📁 libcthreads\n├── 📁 libfcache\n├── 📁 libfdata\n├── 📁 libfdatetime\n├── 📁 libfguid\n├── 📁 libfmapi\n├── 📁 libfvalue\n├── 📁 libfwnt\n├── 📁 libpff\n├── 📄 libpff.ini\n├── 📄 libpff.pc\n├── 📄 libpff.pc.in\n├── 📄 libpff.spec\n├── 📄 libpff.spec.in\n├── 📄 libtool\n├── 📁 libuna\n├── 📄 ltm