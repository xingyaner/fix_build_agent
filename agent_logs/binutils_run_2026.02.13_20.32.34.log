ld: source is at /work/binutils-gdb\n# 2. Local checkout: source is at $SRC (/src)\nif [ -d binutils-gdb ]; then\n    # Case 1: Docker build\n    cd binutils-gdb\nelif [ -d \"$SRC\" ] && [ -f \"$SRC/configure.ac\" ]; then\n    # Case 2: Local checkout - source is at $SRC\n    cd \"$SRC\"\n    echo \"Using local checkout at $(pwd)\"\n    # Copy fuzz_*.c files from /work to current directory for cp ../fuzz_*.c to work\n    # Actually, cp ../fuzz_*.c won't work because we're at $SRC, not /work\n    # We need to handle this differently\n    if [ -f \"/work/fuzz_addr2line.c\" ]; then\n        cp /work/fuzz_*.c .\n    fi\nelse\n    echo \"ERROR: Cannot find binutils source directory\"\n    echo \"Current directory: $(pwd)\"\n    echo \"SRC: $SRC\"\n    echo \"Contents of /work:\"\n    ls -la /work\n    echo \"Contents of $SRC:\"\n    ls -la \"$SRC\"\n    exit 1\nfi"})
