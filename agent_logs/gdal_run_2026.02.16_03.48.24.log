IBS:BOOL=OFF \\\n        -DCMAKE_INSTALL_PREFIX=$SRC/install \\\n        -DCMAKE_BUILD_TYPE=debug \\\n        -DENABLE_OPENMP=OFF \\\n        -DENABLE_SAMPLES=OFF\nmake -j$(nproc) -s\nmake install\ncd ../..\n---=== REPLACEMENT ===---\n# build muparser\ncd muparser\nmkdir build\ncd build\ncmake .. -DBUILD_SHARED_LIBS:BOOL=OFF \\\n        -DCMAKE_INSTALL_PREFIX=$SRC/install \\\n        -DCMAKE_BUILD_TYPE=debug \\\n        -DENABLE_OPENMP=OFF \\\n        -DENABLE_SAMPLES=OFF\nmake -j$(nproc) -s\nmake install\ncd ../..\n\n# Build libwebp from source (need newer version with SharpYUV support)\nrm -rf libwebp\ngit clone --depth 1 https://chromium.googlesource.com/webm/libwebp libwebp\ncd libwebp\n./autogen.sh\n./configure --prefix=$SRC/install --disable-shared --enable-static \\\n            --enable-libwebpdemux --enable-libwebpmux --enable-libwebpdecoder \\\n            --enable-libwebpextras --enable-swap-16bit-csp\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\nexport EXTRA_LIBS=\"$EXTRA_LIBS -ljbig -lzstd -lwebp -llzma -lexpat -L$SRC/install/lib -lsqlite3 -lgif -ljpeg -lpng -lz -lbrotlidec -lbrotlicommon -lbz2\"\n---=== REPLACEMENT ===---\nexport EXTRA_LIBS=\"$EXTRA_LIBS -ljbig -lzstd -lwebp -llzma -lexpat -L$SRC/install/lib -lsqlite3 -lgif -ljpeg -lpng -lz -lbrotlidec -lbrotlicommon -lbz2\"\n---=== FILE ===---\n/root/fix_build_agent/process/project/gdal/fuzzers/build.sh\n---=== ORIGINAL ===---\nexport EXTRA_LIBS=\"$EXTRA_LIBS -Wl,-Bdynamic -ldl -lpthread -lclang_rt.builtins -lsharpyuv\"\n---=== REPLACEMENT ===---\nexport EXTRA_LIBS=\"$EXTRA_LIBS -Wl,-Bdynamic -ldl -lpthread -lclang_rt.builtins\"\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/gdal/Dockerfile\n---=== ORIGINAL ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:0c229e61349e6e5f4dbcfd433b2b0b5906012d49216675a6402ad1ed270715c4\nRUN apt-get update && \\\n    apt-get install -y make autoconf a