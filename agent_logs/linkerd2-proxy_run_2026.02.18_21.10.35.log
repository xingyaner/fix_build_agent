]\nthen\n  export RUSTFLAGS=\"$RUSTFLAGS -C debug-assertions=no\"\n  chmod +x $SRC/rustc.py\n  export RUSTC=\"$SRC/rustc.py\"\n  export CFLAGS=\"\"\nfi\n\n# Function to fix fuzz/Cargo.toml files by adding missing workspace.package.edition\nfix_fuzz_cargo_toml() {\n  local fuzz_dir=\"$1\"\n  local cargo_toml=\"${fuzz_dir}/fuzz/Cargo.toml\"\n  \n  if [ -f \"$cargo_toml\" ]; then\n    echo \"Fixing $cargo_toml\"\n    # Check if workspace.package.edition is missing\n    if ! grep -q \"^\\[workspace.package\\]\" \"$cargo_toml\"; then\n      # Add [workspace.package] section with edition after the [workspace] section\n      sed -i '/^\\[workspace\\]/a[workspace.package]\\nedition = \"2021\"' \"$cargo_toml\"\n    fi\n  fi\n}\n\nBUILD_FUZZER=\"cargo fuzz build \"\nTARGET_PATH=\"./fuzz/target/x86_64-unknown-linux-gnu/release\"\nBASE=\"$SRC/linkerd2-proxy/linkerd\"\n\n# Fix and build each fuzz target\ncd ${BASE}/app/inbound\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_inbound\n\ncd ${BASE}/addr/\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_addr\n\ncd ${BASE}/dns\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_dns\n\ncd ${BASE}/proxy/http\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_http\n\ncd ${BASE}/tls\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_tls\n\ncd ${BASE}/transport-header\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_raw $OUT/fuzz_transport_raw\ncp ${TARGET_PATH}/fuzz_target_structured $OUT/fuzz_transport_structured\n\necho \"[libfuzzer]\" > $OUT/fuzz_transport_raw.options\necho \"detect_leaks=0\" >> $OUT/fuzz_transport_raw.options\n---=== REPLACEMENT ===---\n#!/bin/bash -eu\n# Copyright 2021 Google LLC\n#\n# Licensed under the Apache License, Version 2.0 (the \"License\");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#      http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n################################################################################\n\nif [ \"$SANITIZER\" = \"coverage\" ]\nthen\n  export RUSTFLAGS=\"$RUSTFLAGS -C debug-assertions=no\"\n  chmod +x $SRC/rustc.py\n  export RUSTC=\"$SRC/rustc.py\"\n  export CFLAGS=\"\"\nfi\n\n# Function to fix fuzz/Cargo.toml files by replacing { workspace = true } with actual values\nfix_fuzz_cargo_toml() {\n  local fuzz_dir=\"$1\"\n  local cargo_toml=\"${fuzz_dir}/fuzz/Cargo.toml\"\n  \n  if [ -f \"$cargo_toml\" ]; then\n    echo \"Fixing $cargo_toml\"\n    # Replace { workspace = true } with actual values since fuzz directories have their own workspace\n    sed -i 's/version = { workspace = true }/version = \"0.1.0\"/' \"$cargo_toml\"\n    sed -i 's/license = { workspace = true }/license = \"Apache-2.0\"/' \"$cargo_toml\"\n    sed -i 's/edition = { workspace = true }/edition = \"2021\"/' \"$cargo_toml\"\n    sed -i 's/publish = { workspace = true }/publish = false/' \"$cargo_toml\"\n  fi\n}\n\nBUILD_FUZZER=\"cargo fuzz build \"\nTARGET_PATH=\"./fuzz/target/x86_64-unknown-linux-gnu/release\"\nBASE=\"$SRC/linkerd2-proxy/linkerd\"\n\n# Fix and build each fuzz target\ncd ${BASE}/app/inbound\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_inbound\n\ncd ${BASE}/addr/\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_addr\n\ncd ${BASE}/dns\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_dns\n\ncd ${BASE}/proxy/http\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_http\n\ncd ${BASE}/tls\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_1 $OUT/fuzz_tls\n\ncd ${BASE}/transport-header\nfix_fuzz_cargo_toml \".\"\n${BUILD_FUZZER}\ncp ${TARGET_PATH}/fuzz_target_raw $OUT/fuzz_transport_raw\ncp ${TARGET_PATH}/fuzz_target_structured $OUT/fuzz_transport_structured\n\necho \"[libfuzzer]\" > $OUT/fuzz_transport_raw.options\necho \"detect_leaks=0\" >> $OUT/fuzz_transport_raw.options"})
