fuzzers/build.sh\n---=== ORIGINAL ===---\n# Handle path resolution - build.sh may be executed from /src or /src/PROJ\nif [ -d \"PROJ\" ]; then\n    cd PROJ\nfi\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\n---=== REPLACEMENT ===---\n# Handle path resolution - build.sh may be executed from /src or /src/PROJ\n# Also handle case where we're already in PROJ directory\nif [ -d \"PROJ\" ]; then\n    cd PROJ\nelif [ ! -d \"curl\" ] && [ -d \"../curl\" ]; then\n    # We might be in /src/PROJ already\n    cd ..\nfi\n\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd curl\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\n# build libtiff.a\ncd libtiff\n./autogen.sh\n./configure --disable-shared --prefix=$SRC/install\nmake -j$(nproc)\nmake install\ncd ..\n\nmkdir build\ncd build\n---=== REPLACEMENT ===---\n# build libtiff.a\ncd libtiff\n./autogen.sh\n./configure --disable-shared --prefix=$SRC/install\nmake -j$(nproc)\nmake install\ncd ..\n\nmkdir build\ncd build"})
