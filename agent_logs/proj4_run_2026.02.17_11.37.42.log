{CPPFLAGS:-}\"; export LDFLAGS=\"-L/usr/local/ssl3/lib \\${LDFLAGS:-}\"; ./configure --disable-shared --with-openssl --without-libpsl --prefix=\\$SRC/install --with-ssl=/usr/local/ssl3|g' test/fuzzers/build.sh\n\n# Also add cd $SRC/PROJ before building curl (but curl is now at /src/curl, not in PROJ)\nRUN sed -i '39i# Change to PROJ directory for PROJ build\\ncd $SRC/PROJ' test/fuzzers/build.sh\n\n# Cache busting: Add timestamp to ensure updated build.sh is copied\nRUN echo \"Build timestamp: $(date)\" && cp test/fuzzers/build.sh $SRC/\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\nI386_PACKAGES=\"zlib1g-dev:i386 libssl-dev:i386 libsqlite3-dev:i386\"\nX64_PACKAGES=\"zlib1g-dev libssl-dev libsqlite3-dev\"\n\nif [ \"$ARCHITECTURE\" = \"i386\" ]; then\n    apt-get install -y $I386_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\" -DSQLite3_LIBRARY=/lib/i386-linux-gnu/libsqlite3.a\"\nelse\n    apt-get install -y $X64_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\"\"\nfi\n---=== REPLACEMENT ===---\nI386_PACKAGES=\"zlib1g-dev:i386 libsqlite3-dev:i386\"\nX64_PACKAGES=\"zlib1g-dev libsqlite3-dev\"\n\nif [ \"$ARCHITECTURE\" = \"i386\" ]; then\n    apt-get install -y $I386_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\" -DSQLite3_LIBRARY=/lib/i386-linux-gnu/libsqlite3.a\"\nelse\n    apt-get install -y $X64_PACKAGES\n    PROJ_CMAKE_EXTRA_ARGS=\"\"\nfi\n---=== FILE ===---\n/root/fix_build_agent/process/project/proj4/test/fuzzers/build.sh\n---=== ORIGINAL ===---\n# build libcurl.a (building against Ubuntu libcurl.a doesn't work easily)\ncd /src/curl\nautoreconf -i\nPKG_CONFIG_PATH=/usr/local/ssl3/lib/pkgconfig:$PKG_CONFIG_PATH CPPFLAGS=\"-I/usr/local/ssl3/include $CPPFLAGS\" LDFLAGS=\"-L/usr/local/ssl3/lib $LDFLAGS\" ./configure --disable-shared --with-openssl --without-libpsl --prefix=$SRC/install --with-ssl=/usr/local/ssl3\nmake clean -s\nmake -j$(nproc) -s\nmake install\ncd ..\n---=== REPLACEMENT ===---\n# build libcurl.a (building against 