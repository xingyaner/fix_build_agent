\nRUN git clone  https://github.com/lsh123/xmlsec\nRUN git clone  https://gitlab.gnome.org/GNOME/libxml2.git\nRUN git clone  https://gitlab.gnome.org/GNOME/libxslt.git\nCOPY build.sh *.diff $SRC/\n---=== REPLACEMENT ===---\nFROM gcr.io/oss-fuzz-base/base-builder@sha256:81c0c136cda1ba3f85fd41f65851f7feb942a5fc0aeca4c4f02fb53fa5e835d8\nRUN apt-get update && apt-get install -y make autoconf automake libtool pkg-config \\\n    libssl-dev wget liblzma-dev python-dev python3-dev\n# Build requires automake 1.16.3\nRUN curl -LO http://mirrors.kernel.org/ubuntu/pool/main/a/automake-1.16/automake_1.16.5-1.3_all.deb && \\\n    apt install ./automake_1.16.5-1.3_all.deb    \n# Clone xmlsec (this will be used if not overwritten by mount)\nRUN git clone https://github.com/lsh123/xmlsec\nRUN git clone https://gitlab.gnome.org/GNOME/libxml2.git\nRUN git clone https://gitlab.gnome.org/GNOME/libxslt.git\nCOPY build.sh *.diff $SRC/\n---=== FILE ===---\n/root/fix_build_agent/oss-fuzz/projects/xmlsec/build.sh\n---=== ORIGINAL ===---\nfor file in $SRC/xmlsec/tests/oss-fuzz/*_target.c; do\n    b=$(basename $file _target.c)\n    echo -e \"#include <stdint.h>\\n$(cat $file)\" > $file\n    $CC $CFLAGS -c $file -I${XMLSEC_DEPS_PATH=}/include/libxml2 -I${XMLSEC_DEPS_PATH=}/include/ -I ./include/ \\\n    -o $OUT/${b}_target.o\n    $CXX $CXXFLAGS $OUT/${b}_target.o ./src/.libs/libxmlsec1.a \\\n    ./src/openssl/.libs/libxmlsec1-openssl.a $LIB_FUZZING_ENGINE \\\n    \"$XMLSEC_DEPS_PATH\"/lib/libxslt.a \"$XMLSEC_DEPS_PATH\"/lib/libxml2.a \\\n    -lz -llzma -o $OUT/${b}_fuzzer\ndone\n---=== REPLACEMENT ===---\n# Check if xmlsec tests directory exists\nif [ -d \"$SRC/xmlsec/tests/oss-fuzz\" ]; then\n    for file in $SRC/xmlsec/tests/oss-fuzz/*_target.c; do\n        b=$(basename $file _target.c)\n        echo -e \"#include <stdint.h>\\n$(cat $file)\" > $file\n        $CC $CFLAGS -c $file -I${XMLSEC_DEPS_PATH=}/include/libxml2 -I${XMLSEC_DEPS_PATH=}/include/ -I ./include/ \\\n        -o $OUT/${b}_target.o\n        $CXX $CXXFLAGS $OUT/${b}_target.o ./src/.libs/libxmlsec1.a \\\n        ./src/openssl/.libs/libxmlsec1-openssl.a $LIB_FUZZING_ENGINE \\\n        \"$XMLSEC_DEPS_PATH\"/lib/libxslt.a \"$XMLSEC_DEPS_PATH\"/lib/libxml2.a \\\n        -lz -llzma -o $OUT/${b}_fuzzer\n    done\nelse\n    echo \"Error: xmlsec tests directory not found at $SRC/xmlsec/tests/oss-fuzz\"\n    echo \"Make sure xmlsec source is correctly cloned and built\"\n    exit 1\nfi"})
